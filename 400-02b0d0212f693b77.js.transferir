"use strict";(self.webpackChunk_N_E=self.webpackChunk_N_E||[]).push([[400],{168:(e,a,n)=>{n.d(a,{P:()=>i});let i={nav_about:{pt:"Sobre Mim",en:"About Me",fr:"\xc0 Propos de Moi",de:"\xdcber Mich",es:"Sobre M\xed",zh:"关于我"},nav_golden_tips:{pt:"Dicas de Ouro",en:"Golden Nuggets",fr:"Conseils d'Or",de:"Goldene Tipps",es:"Consejos de Oro",zh:"金玉良言"},nav_contact:{pt:"Entre em Contacto",en:"Contact Me",fr:"Contactez-moi",de:"Kontakt",es:"Contacto",zh:"联系我"},nav_evaluate:{pt:"Avaliar",en:"Evaluate",fr:"\xc9valuer",de:"Bewerten",es:"Evaluar",zh:"房产估价"},nav_read:{pt:"Ler",en:"Read",fr:"Lire",de:"Lesen",es:"Leer",zh:"阅读"},nav_menu_accessibility_title:{pt:"Menu de Navega\xe7\xe3o",en:"Navigation Menu",fr:"Menu de Navigation",de:"Navigationsmen\xfc",es:"Men\xfa de Navegaci\xf3n",zh:"导航菜单"},nav_menu_accessibility_description:{pt:"Explore o site e descubra as melhores oportunidades imobili\xe1rias.",en:"Explore the site and discover the best real estate opportunities.",fr:"Explorez le site et d\xe9couvrez les meilleures opportunit\xe9s immobili\xe8res.",de:"Erkunden Sie die Website und entdecken Sie die besten Immobilienangebote.",es:"Explore el sitio y descubra as melhores oportunidades inmobiliarias.",zh:"浏览网站，发现最佳房地产机会。"},home_hero_button:{pt:"AVALIA\xc7\xc3O EM SEGUNDOS",en:"EVALUATION IN SECONDS",fr:"\xc9VALUATION EN QUELQUES SECONDES",de:"SEKUNDENSCHNELLE BEWERTUNG",es:"EVALUACI\xd3N EN SEGUNDOS",zh:"秒速估价"},home_blog_title:{pt:"Destaques do Blog",en:"Blog Highlights",fr:"Points forts du blog",de:"Blog-Highlights",es:"Destacados del Blog",zh:"博客亮点"},home_blog_button:{pt:"Ver Todos os Artigos",en:"View All Articles",fr:"Voir tous les articles",de:"Alle Artikel ansehen",es:"Ver todos los art\xedculos",zh:"查看所有文章"},services_title:{pt:"O Meu Compromisso",en:"My Commitment",fr:"Mon Engagement",de:"Mein Versprechen",es:"Mi Compromiso",zh:"我的承诺"},services_subtitle:{pt:"Ofere\xe7o um acompanhamento de excel\xeancia em todo o processo, garantindo a sua m\xe1xima satisfa\xe7\xe3o e tranquilidade.",en:"I offer excellent support throughout the entire process, ensuring your utmost satisfaction and peace of mind.",fr:"J'offre un excellent accompagnement tout au long du processus, garantissant votre plus grande satisfaction et tranquillit\xe9 d'esprit.",de:"Ich biete exzellente Unterst\xfctzung w\xe4hrend des gesamten Prozesses, um Ihre h\xf6chste Zufriedenheit und Sorgenfreiheit zu gew\xe4hrleisten.",es:"Ofrezco un acompanhamento de excelencia en todo el proceso, garantizando su m\xe1xima satisfacci\xf3n y tranquilidad.",zh:"我在整个过程中提供卓越的支持，确保您最大程度的满意和安心。"},service_1_title:{pt:"PREPARA\xc7\xc3O DO IM\xd3VEL",en:"PROPERTY PREPARATION",fr:"PR\xc9PARATION DU BIEN",de:"OBJEKTVORBEREITUNG",es:"PREPARACI\xd3N DEL INMUEBLE",zh:"房源准备"},service_1_desc:{pt:"Garanto uma apresenta\xe7\xe3o irrepreens\xedvel do seu im\xf3vel. Cuido de todas as valida\xe7\xf5es legais e documentais com apoio especializado, defino a melhor estrat\xe9gia de pre\xe7o atrav\xe9s de uma an\xe1lise de mercado aprofundada e produzo uma reportagem fotogr\xe1fica e v\xeddeo profissional, complementada com 'home staging' para valorizar o espa\xe7o.",en:"I ensure an impeccable presentation of your property. I handle all legal and documentary validations with specialized support, define the best pricing strategy through in-depth market analysis, and produce a professional photo and video report, complemented with home staging to enhance the space.",fr:"Je garantis une pr\xe9sentation irr\xe9prochable de votre bien. Je m'occupe de toutes les validations l\xe9gales et documentaires avec un soutien sp\xe9cialis\xe9, d\xe9finis la meilleure strat\xe9gie de prix gr\xe2ce \xe0 une analyse approfondie du march\xe9 et produis un reportage photo et vid\xe9o professionnel, compl\xe9t\xe9 par du 'home staging' pour valoriser l'espace.",de:"Ich sorge f\xfcr eine makellose Pr\xe4sentation Ihrer Immobilie. Ich k\xfcmmere mich um alle rechtlichen und dokumentarischen Validierungen mit spezialisierter Unterst\xfctzung, definiere die beste Preisstrategie durch eine tiefgehende Marktanalyse und erstelle einen professionellen Foto- und Videobericht, erg\xe4nzt durch Home Staging zur Aufwertung des Raumes.",es:"Garantizo una presentaci\xf3n impecable de su inmueble. Me ocupo de todas las validaciones legales y documentales con apoyo especializado, defino la melhor estrategia de precios a trav\xe9s de un an\xe1lisis de mercado profundo y produzco un reportaje fotogr\xe1fico y de v\xeddeo profesional, complementado con 'home staging' para valorar el espacio.",zh:"我确保您的房产以完美无瑕的形象呈现。我负责处理所有法律和文件验证，提供专业支持，通过深入的市场分析确定最佳定价策略，并制作专业的照片和视频报告，辅以家居布置以提升空间价值。"},service_2_title:{pt:"PROMO\xc7\xc3O COM IA",en:"AI-POWERED PROMOTION",fr:"PROMOTION AVEC IA",de:"KI-GEST\xdcTZTE VERMARKTUNG",es:"PROMOCI\xd3N CON IA",zh:"人工智能营销"},service_2_desc:{pt:"Elaboro um plano de marketing e promo\xe7\xe3o, validando todas as a\xe7\xf5es consigo (campanhas, 'open house', etc.). Gero descri\xe7\xf5es profissionais e otimizadas com I.A., utilizando esta tecnologia em todo o processo — do marketing \xe0 an\xe1lise de mercado — para garantir a m\xe1xima exposi\xe7\xe3o, o pre\xe7o certo e o melhor acompanhamento.",en:"I create a marketing and promotion plan, validating all actions with you (campaigns, open houses, etc.). I generate professional and optimized descriptions with AI, using this technology throughout the process—from marketing to market analysis—to ensure maximum exposure, the right price, and the best support.",fr:"J'\xe9labore un plan de marketing et de promotion, en validant toutes les actions avec vous (campagnes, journ\xe9es portes ouvertes, etc.). Je g\xe9n\xe8re des descriptions professionnelles et optimis\xe9es avec l'IA, en utilisant cette technologie tout au long du processus - du marketing \xe0 l'analyse de march\xe9 - pour garantir une exposition maximale, le juste prix et le meilleur suivi.",de:"Ich erstelle einen Marketing- und Verkaufsf\xf6rderungsplan und validiere alle Aktionen mit Ihnen (Kampagnen, Open House etc.). Ich generiere professionelle und optimierte Beschreibungen mit KI und nutze diese Technologie im gesamten Prozess – vom Marketing bis zur Marktanalyse – um maximale Reichweite, den richtigen Preis und die beste Betreuung zu gew\xe4hrleisten.",es:"Elaboro un plan de marketing y promoci\xf3n, validando todas las acciones con usted (campa\xf1as, 'open house', etc.). Genero descripciones profesionales y optimizadas con IA, utilizando esta tecnolog\xeda en todo o processo —del marketing al an\xe1lisis de mercado— para garantizar la m\xe1xima exposici\xf3n, el precio correcto y el melhor seguimiento.",zh:"我负责制定营销推广计划，并与您确认所有活动（如广告系列、开放日等）。我利用人工智能生成专业且优化的房产描述，并在从市场营销到市场分析的整个过程中运用该技术，以确保最大程度的曝光、最合适的价格和最优质的跟进服务。"},service_3_title:{pt:"GEST\xc3O COMERCIAL",en:"COMMERCIAL MANAGEMENT",fr:"GESTION COMMERCIALE",de:"KOMMERZIELLES MANAGEMENT",es:"GESTI\xd3N COMERCIAL",zh:"商务管理"},service_3_desc:{pt:"Assumo toda a gest\xe3o comercial: crio uma base de dados de interessados, qualifico a sua motiva\xe7\xe3o e capacidade de compra com parceiros de cr\xe9dito, e valido o 'match' com o im\xf3vel. Trato do agendamento de visitas, do reporting de a\xe7\xf5es e proponho melhorias, garantindo um processo transparente e sem stress para si.",en:"I handle all commercial management: creating a database of interested parties, qualifying their motivation and purchasing power with credit partners, and validating the property match. I manage visit scheduling, action reporting, and propose improvements, ensuring a transparent and stress-free process for you.",fr:"Je prends en charge toute la gestion commerciale : je cr\xe9e une base de donn\xe9es de prospects, je qualifie leur motivation et leur capacit\xe9 d'achat avec des partenaires de cr\xe9dit, et je valide l'ad\xe9quation avec le bien. Je m'occupe de la planification des visites, du reporting des actions et je propose des am\xe9liorations, garantissant un processus transparent et sans stress pour vous.",de:"Ich \xfcbernehme die gesamte kaufm\xe4nnische Verwaltung: Erstellung einer Datenbank von Interessenten, Qualifizierung ihrer Motivation und Kaufkraft mit Kreditpartnern und Validierung der \xdcbereinstimmung mit der Immobilie. Ich k\xfcmmere mich um die Terminplanung f\xfcr Besichtigungen, das Berichtswesen \xfcber die Ma\xdfnahmen und schlage Verbesserungen vor, um einen transparenten und stressfreien Prozess f\xfcr Sie zu gew\xe4hrleisten.",es:"Asumo toda la gesti\xf3n comercial: creo una base de datos de interesados, cualifico su motivaci\xf3n y capacidad de compra con socios de cr\xe9dito, y valido el 'match' con el inmueble. Me encargo de la programaci\xf3n de visitas, del reporting de acciones y propongo mejoras, garantizando un proceso transparente y sin estr\xe9s para usted.",zh:"我负责所有商务管理：建立潜在客户数据库，与信贷合作伙伴一起评估其购买动机和购买力，并确认其与房产的匹配度。我处理看房安排、活动报告并提出改进建议，确保为您提供一个透明无忧的流程。"},service_4_title:{pt:"FECHO DO NEG\xd3CIO",en:"CLOSING THE DEAL",fr:"CONCLUSION DE LA VENTE",de:"VERTRAGSABSCHLUSS",es:"CIERRE DEL NEGOCIO",zh:"交易收尾"},service_4_desc:{pt:"Acompanho-o pessoalmente em todas as fases do fecho do neg\xf3cio. Lidero a negocia\xe7\xe3o, gerindo as expectativas e defendendo os seus interesses. Facilito o acesso a cr\xe9dito aos compradores atrav\xe9s de parceiros, sem custos, e coordeno todo o processo administrativo at\xe9 \xe0 escritura, garantindo que tudo corre na perfei\xe7\xe3o.",en:"I personally accompany you through all stages of closing the deal. I lead the negotiation, managing expectations and defending your interests. I facilitate buyers' access to credit through partners at no cost, and coordinate the entire administrative process up to the deed, ensuring everything runs smoothly.",fr:"Je vous accompagne personnellement \xe0 toutes les \xe9tapes de la conclusion de la vente. Je m\xe8ne la n\xe9gociation, en g\xe9rant les attentes et en d\xe9fendant vos int\xe9r\xeats. Je facilite l'acc\xe8s au cr\xe9dit pour les acheteurs via des partenaires, sans frais, et je coordonne tout le processus administratif jusqu'\xe0 l'acte de vente, en veillant \xe0 ce que tout se d\xe9roule parfaitement.",de:"Ich begleite Sie pers\xf6nlich durch alle Phasen des Gesch\xe4ftsabschlusses. Ich f\xfchre die Verhandlungen, manage die Erwartungen und verteidige Ihre Interessen. Ich erleichtere den K\xe4ufern den Zugang zu Krediten durch Partner ohne zus\xe4tzliche Kosten und koordiniere den gesamten administrativen Prozess bis zur Unterzeichnung des Kaufvertrags, um sicherzustellen, dass alles reibungslos abl\xe4uft.",es:"Le acompa\xf1o personalmente en todas las fases del cierre del negocio. Lidero la negociaci\xf3n, gestionando las expectativas y defendiendo sus intereses. Facilito el acceso a cr\xe9dito a los compradores a trav\xe9s de socios, sin costes, e coordino todo o processo administrativo hasta la escritura, garantizando que todo salga a la perfecci\xf3n.",zh:"我将亲自陪同您完成交易收尾的各个阶段。我主导谈判，管理期望并捍卫您的利益。我通过合作伙伴为买家提供免费的信贷渠道，并协调从签约到交割的整个行政流程，确保一切顺利进行。"},contact_form_title:{pt:"Entre em Contacto",en:"Get in Touch",fr:"Contactez-moi",de:"Kontakt aufnehmen",es:"P\xf3ngase en Contacto",zh:"联系我"},contact_form_subtitle:{pt:"Estou aqui para o ajudar. Preencha o formul\xe1rio e entrarei em contacto consigo.",en:"I'm here to help. Fill out the form and I'll get in touch with you.",fr:"Je suis l\xe0 pour vous aider. Remplissez le formulaire et je vous contacterai.",de:"Ich bin hier, um zu helfen. F\xfcllen Sie das Formular aus und ich werde mich bei Ihnen melden.",es:"Estoy aqu\xed para ayudar. Rellene el formulario y me pondr\xe9 en contacto con usted.",zh:"我在这里随时为您提供帮助。请填写此表格，我会尽快与您联系。"},contact_form_objective:{pt:"Qual \xe9 o seu objetivo?",en:"What is your goal?",fr:"Quel est votre objectif ?",de:"Was ist Ihr Ziel?",es:"\xbfCu\xe1l es su objetivo?",zh:"您的目标是什么？"},contact_form_sell:{pt:"Vender",en:"Sell",fr:"Vendre",de:"Verkaufen",es:"Vender",zh:"出售"},contact_form_buy:{pt:"Comprar",en:"Buy",fr:"Acheter",de:"Kaufen",es:"Comprar",zh:"购买"},contact_form_name:{pt:"Nome",en:"Name",fr:"Nom",de:"Name",es:"Nombre",zh:"姓名"},contact_form_name_placeholder:{pt:"O seu nome completo",en:"Your full name",fr:"Votre nom complet",de:"Ihr vollst\xe4ndiger Name",es:"Su nombre completo",zh:"您的全名"},contact_form_email:{pt:"Email",en:"Email",fr:"Email",de:"E-Mail",es:"Email",zh:"电子邮件"},contact_form_email_placeholder:{pt:"O seu melhor email",en:"Your best email",fr:"Votre meilleure adresse e-mail",de:"Ihre beste E-Mail-Adresse",es:"Su melhor email",zh:"您的常用邮箱"},contact_form_address:{pt:"Morada do Im\xf3vel (Opcional)",en:"Property Address (Optional)",fr:"Adresse du bien (Optionnel)",de:"Adresse der Immobilie (Optional)",es:"Direcci\xf3n del Inmueble (Opcional)",zh:"房产地址（可选）"},contact_form_address_placeholder:{pt:"Ex: Rua da Liberdade, 123",en:"Ex: 123 Freedom Street",fr:"Ex: 123, rue de la Libert\xe9",de:"Z.B. Freiheitsstra\xdfe 123",es:"Ej: Calle de la Libertad, 123",zh:"例如：自由路123号"},contact_form_type:{pt:"Tipologia (Opcional)",en:"Type (Optional)",fr:"Typologie (Optionnel)",de:"Typ (Optional)",es:"Tipolog\xeda (Opcional)",zh:"户型（可选）"},contact_form_zones:{pt:"Zonas de Prefer\xeancia (Opcional)",en:"Preferred Areas (Optional)",fr:"Zones pr\xe9f\xe9r\xe9es (Optionnel)",de:"Bevorzugte Gebiete (Optional)",es:"Zonas de Preferencia (Opcional)",zh:"首选区域（可选）"},contact_form_zones_placeholder:{pt:"Ex: Lisboa, Porto",en:"Ex: Lisbon, Porto",fr:"Ex: Lisbonne, Porto",de:"Z.B. Lissabon, Porto",es:"Ej: Lisboa, Oporto",zh:"例如：里斯本、波尔图"},contact_form_type_desired:{pt:"Tipologia Desejada (Opcional)",en:"Desired Type (Optional)",fr:"Typologie Souhait\xe9e (Optionnel)",de:"Gew\xfcnschter Typ (Optional)",es:"Tipolog\xeda Deseada (Opcional)",zh:"期望户型（可选）"},contact_form_message:{pt:"Mensagem",en:"Message",fr:"Message",de:"Nachricht",es:"Mensaje",zh:"留言"},contact_form_message_placeholder:{pt:"Fale-me um pouco mais sobre o que procura...",en:"Tell me a little more about what you are looking for...",fr:"Dites-m’en un peu plus sur ce que vous recherchez…",de:"Erz\xe4hlen Sie mir etwas mehr dar\xfcber, was Sie suchen...",es:"Cu\xe9nteme un poco m\xe1s sobre lo que est\xe1 buscando...",zh:"请详细描述您的需求…"},contact_form_submit:{pt:"Enviar Pedido",en:"Send Request",fr:"Envoyer la demande",de:"Anfrage senden",es:"Enviar Solicitud",zh:"发送请求"},contact_form_submitting:{pt:"A Enviar...",en:"Sending...",fr:"Envoi en cours...",de:"Wird gesendet...",es:"Enviando...",zh:"发送中..."},contact_form_select_placeholder_type:{pt:"Selecione a tipologia",en:"Select the type",fr:"S\xe9lectionnez le type",de:"W\xe4hlen Sie den Typ aus",es:"Seleccione la tipolog\xeda",zh:"选择户型"},about_title:{pt:"Sobre Mim",en:"About Me",fr:"\xc0 Propos de Moi",de:"\xdcber Mich",es:"Sobre M\xed",zh:"关于我"},about_bio_1:{pt:"Aos 21 anos, encaro o mercado imobili\xe1rio n\xe3o apenas como uma profiss\xe3o, mas como o terreno ideal para aplicar uma \xe9tica de trabalho que cultivo desde muito cedo. Embora o percurso acad\xe9mico tradicional fosse uma op\xe7\xe3o vi\xe1vel — as notas permitiam-no —, tomei a decis\xe3o consciente de ingressar diretamente no mercado de trabalho, movido pela vontade de aprender na pr\xe1tica e de construir uma carreira s\xf3lida. A minha verdadeira escola foi a a\xe7\xe3o, o risco calculado e a resolu\xe7\xe3o de problemas reais.",en:"At 21, I see the real estate market not just as a profession, but as the ideal ground to apply a work ethic I've cultivated from a very young age. Although a traditional academic path was a viable option—my grades allowed it—I made the conscious decision to enter the workforce directly, driven by the desire to learn hands-on and build a solid career. My true school has been action, calculated risk, and solving real problems.",fr:"\xc0 21 ans, je vois le march\xe9 immobilier non seulement comme une profession, mas como le terrain id\xe9al pour appliquer une \xe9thique de travail que je cultive depuis mon plus jeune \xe2ge. Bien qu'un parcours acad\xe9mique traditionnel ait \xe9t\xe9 une option viable - mes notes le permettaient - j'ai pris la d\xe9cision consciente d'entrer directement sur le march\xe9 du travail, motiv\xe9 par le d\xe9sir d'apprendre sur le terrain et de construire une carri\xe8re solide. Ma v\xe9ritable \xe9cole a \xe9t\xe9 l'action, le risque calcul\xe9 et la r\xe9solution de probl\xe8mes r\xe9els.",de:"Mit 21 Jahren betrachte ich den Immobilienmarkt nicht nur als Beruf, sondern als idealen N\xe4hrboden, um eine von klein auf gepflegte Arbeitsmoral anzuwenden. Obwohl ein traditioneller akademischer Weg eine realistische Option war – meine Noten erlaubten es –, traf ich die bewusste Entscheidung, direkt in die Arbeitswelt einzusteigen, angetrieben von dem Wunsch, praxisnah zu lernen und eine solide Karriere aufzubauen. Meine wahre Schule war das Handeln, das kalkulierte Risiko und das L\xf6sen realer Probleme.",es:"A los 21 a\xf1os, veo el mercado inmobiliario no solo como una profesi\xf3n, sino como el terreno ideal para aplicar una \xe9tica de trabajo que he cultivado desde muy joven. Aunque la v\xeda acad\xe9mica tradicional era una opci\xf3n viable —mis notas lo permit\xedan—, tom\xe9 la decisi\xf3n consciente de incorporarme directamente al mercado laboral, movido por el deseo de aprender en la pr\xe1ctica y construir una carrera s\xf3lida. Mi verdadera escuela ha sido la acci\xf3n, el riesgo calculado y la resoluci\xf3n de problemas reales.",zh:"21岁的我，不仅将房地产市场视为一份职业，更将其看作是实践我从小培养的职业道德的理想平台。尽管传统的学术道路对我来说是可行的——我的成绩足以支持——但我还是毅然决然地选择直接进入职场，渴望通过实践学习并建立稳固的职业生涯。我真正的学堂是行动、是经过计算的风险、是解决真实世界问题的过程。"},about_bio_2:{pt:"O meu perfil profissional \xe9 o resultado de experi\xeancias intensas e diversificadas. A minha disciplina foi forjada na organiza\xe7\xe3o de eventos, tanto em Portugal como na Alemanha, onde a precis\xe3o e a capacidade de resolver problemas sob press\xe3o eram fundamentais. Quem conhece este setor sabe que n\xe3o h\xe1 margem para falhas: a pontualidade e o sangue-frio s\xe3o obrigat\xf3rios.",en:"My professional profile is the result of intense and diverse experiences. My discipline was forged in event organization, both in Portugal and Germany, where precision and the ability to solve problems under pressure were fundamental. Anyone who knows this sector knows there is no room for error: punctuality and composure are mandatory.",fr:"Mon profil professionnel est le r\xe9sultat d'exp\xe9riences intenses et diversifi\xe9es. Ma discipline a \xe9t\xe9 forg\xe9e dans l'organisation d'\xe9v\xe9nements, tant au Portugal qu'en Allemagne, o\xf9 la pr\xe9cision et la capacit\xe9 \xe0 r\xe9soudre les probl\xe8mes sous pression \xe9taient fondamentales. Quiconque conna\xeet ce secteur sait qu'il n'y a pas de place pour l'erreur : la ponctualit\xe9 et le sang-froid sont obligatoires.",de:"Mein berufliches Profil ist das Ergebnis intensiver und vielf\xe4ltiger Erfahrungen. Meine Disziplin wurde bei der Organisation von Veranstaltungen in Portugal und Deutschland geschmiedet, wo Pr\xe4zision und die F\xe4higkeit, Probleme unter Druck zu l\xf6sen, von grundlegender Bedeutung waren. Wer diese Branche kennt, wei\xdf, dass es keinen Raum f\xfcr Fehler gibt: P\xfcnktlichkeit und Gelassenheit sind unerl\xe4sslich.",es:"Mi perfil profesional es el resultado de experiencias intensas y diversificadas. Mi disciplina se forj\xf3 en la organizaci\xf3n de eventos, tanto en Portugal como en Alemania, donde la precisi\xf3n y la capacidad para resolver problemas bajo presi\xf3n eran fundamentales. Quien conoce este sector sabe que no hay margen para el error: la puntualidad y la sangre fr\xeda son obligatorias.",zh:"我的职业背景源于丰富而深刻的多元化经历。我的纪律性是在葡萄牙和德国组织活动时磨练出来的，在那些场合，精确性和在压力下解决问题的能力至关重要。了解这个行业的人都知道，这里不容许任何失误：守时和沉着是必须具备的品质。"},about_bio_3:{pt:"Paralelamente, o meu esp\xedrito empreendedor conduziu-me ao exigente mundo da importa\xe7\xe3o e com\xe9rcio autom\xf3vel. Esta experi\xeancia apurou o meu instinto comercial, a capacidade de negocia\xe7\xe3o e a log\xedstica necess\xe1ria para concretizar neg\xf3cios complexos.",en:"In parallel, my entrepreneurial spirit led me to the demanding world of car import and trade. This experience sharpened my commercial instinct, negotiation skills, and the logistics required to complete complex deals.",fr:"En parall\xe8le, mon esprit d'entreprise m'a conduit dans le monde exigeant de l'importation et du commerce automobile. Cette exp\xe9rience a aiguis\xe9 mon instinct commercial, ma capacit\xe9 de n\xe9gociation et la logistique n\xe9cessaire pour mener \xe0 bien des transactions complexes.",de:"Gleichzeitig f\xfchrte mich mein Unternehmergeist in die anspruchsvolle Welt des Autoimports und -handels. Diese Erfahrung sch\xe4rfte meinen Gesch\xe4ftssinn, meine Verhandlungsf\xe4higkeiten und die logistischen Kenntnisse, die f\xfcr den Abschluss komplexer Gesch\xe4fte erforderlich sind.",es:"Paralelamente, mi esp\xedritu emprendedor me llev\xf3 al exigente mundo de la importaci\xf3n y el comercio de autom\xf3viles. Esta experiencia agudiz\xf3 mi instinto comercial, mi capacidad de negociaci\xf3n y la log\xedstica necesaria para cerrar tratos complejos.",zh:"同时，我的创业精神引领我进入了要求严苛的汽车进出口贸易领域。这段经历磨练了我的商业直觉、谈判技巧以及完成复杂交易所必需的物流操作能力。"},about_bio_4:{pt:"A alicer\xe7ar toda esta atividade profissional est\xe1 a mentalidade de um atleta federado. A pr\xe1tica di\xe1ria de Kickboxing incutiu-me um rigor e uma resili\xeancia mental que transponho para o meu dia a dia: aprendi que a consist\xeancia \xe9 a chave e que nunca se vira a cara a um desafio.",en:"Underpinning all this professional activity is the mindset of a federated athlete. The daily practice of Kickboxing has instilled in me a rigor and mental resilience that I carry into my daily life: I learned that consistency is key and that you never turn your back on a challenge.",fr:"Le fondement de toute cette activit\xe9 professionnelle est la mentalit\xe9 d'un athl\xe8te f\xe9d\xe9r\xe9. La pratique quotidienne du kickboxing m'a inculqu\xe9 une rigueur et une r\xe9silience mentale que je transpose dans ma vie de tous les jours : j'ai appris que la constance est la cl\xe9 et qu'on ne recule jamais devant un d\xe9fi.",de:"Die Grundlage all dieser beruflichen T\xe4tigkeiten ist die Mentalit\xe4t eines Verbandssportlers. Die t\xe4gliche Aus\xfcbung des Kickboxens hat mir eine Strenge und geistige Widerstandsf\xe4higkeit verliehen, die ich in mein t\xe4gliches Leben \xfcbertrage: Ich habe gelernt, dass Best\xe4ndigkeit der Schl\xfcssel ist und dass man sich einer Herausforderung niemals entzieht.",es:"La base de toda esta actividad profesional es la mentalidad de un atleta federado. La pr\xe1ctica diaria de Kickboxing me ha inculcado un rigor y una resiliencia mental que traslado a mi d\xeda a dia: he aprendido que la constancia es la clave y que nunca se le da la espalda a un desaf\xedo.",zh:"支撑我所有职业活动的是注册运动员的心态。每日的自由搏击训练为我注入了严谨和坚韧的精神力，我将其运用到日常生活中：我学到了持之以恒是成功的关键，并且永远不能畏惧挑战。"},about_bio_5:{pt:'Hoje, como Consultor Imobili\xe1rio, re\xfano o melhor destes mundos: a precis\xe3o na gest\xe3o de processos, a agilidade comercial de quem sabe vender e a consist\xeancia de um atleta. N\xe3o sou apenas um consultor que abre portas; sou um parceiro de neg\xf3cios que alia a inova\xe7\xe3o tecnol\xf3gica \xe0quela "garra" de quem n\xe3o descansa at\xe9 o objetivo estar cumprido.',en:"Today, as a Real Estate Consultant, I bring together the best of these worlds: precision in process management, the commercial agility of someone who knows how to sell, and the consistency of an athlete. I am not just a consultant who opens doors; I am a business partner who combines technological innovation with the 'grit' of someone who doesn't rest until the goal is achieved.",fr:"Aujourd'hui, en tant que consultant immobilier, je r\xe9unis le meilleur de ces mondes : la pr\xe9cision dans la gestion des processus, l'agilidade commerciale de quelqu'un qui sait vendre et la constance d'un athl\xe8te. Je ne suis pas seulement un consultant qui ouvre des portes ; je suis un partenaire d'affaires qui allie l'innovation technologique \xe0 la 'hargne' de celui qui ne se repose pas avant que l'objectif ne soit atteint.",de:"Heute, als Immobilienberater, vereine ich das Beste aus diesen Welten: Pr\xe4zision im Prozessmanagement, die kaufm\xe4nnische Agilit\xe4t eines Verk\xe4ufers und die Best\xe4ndigkeit eines Athleten. Ich bin nicht nur ein Berater, der T\xfcren \xf6ffnet; ich bin ein Gesch\xe4ftspartner, der technologische Innovation mit dem „Biss“ von jemandem verbindet, der nicht ruht, bis das Ziel erreicht ist.",es:'Hoy, como Consultor Inmobiliario, uno lo mejor de estos mundos: la precisi\xf3n en la gesti\xf3n de procesos, la agilidad comercial de quien sabe vender y la constancia de un atleta. No soy solo un consultor que abre puertas; soy un socio de negocios que combina la innovaci\xf3n tecnol\xf3gica con la "garra" de quien no descansa hasta que el objetivo se cumple.',zh:"如今，作为一名房地产顾问， I 融合了这些领域的精华：流程管理上的精准、销售专家的商业敏锐度，以及运动员般的持之以恒。我不仅仅是为您打开房门的顾问，更是一位商业伙伴，将技术创新与不达目标不罢休的“拼搏精神”相结合。"},about_distinction_title:{pt:"O Que Me Distingue",en:"What Sets Me Apart",fr:"Ce Qui Me Distingue",de:"Was Mich Auszeichnet",es:"Lo Que Me Distingue",zh:"我的独特之处"},about_distinction_1_title:{pt:"Tecnologia de Ponta",en:"Cutting-Edge Technology",fr:"Technologie de Pointe",de:"Spitzentechnologie",es:"Tecnolog\xeda de Vanguardia",zh:"尖端技术"},about_distinction_1_desc:{pt:"Vou al\xe9m do tradicional. Utilizo as mais recentes ferramentas de Intelig\xeancia Artificial para criar descri\xe7\xf5es de im\xf3veis que cativam, para segmentar campanhas de marketing que atingem o comprador ideal e para realizar an\xe1lises de mercado precisas. Isto n\xe3o \xe9 apenas um truque; \xe9 a garantia de que o seu im\xf3vel tem a m\xe1xima visibilidade e \xe9 apresentado ao seu melhor pre\xe7o.",en:"I go beyond the traditional. I use the latest Artificial Intelligence tools to create captivating property descriptions, to segment marketing campaigns that reach the ideal buyer, and to perform accurate market analyses. This isn't just a gimmick; it's the guarantee that your property gets maximum visibility and is presented at its best price.",fr:"Je vais au-del\xe0 du traditionnel. J'utilise les derniers outils d'Intelligence Artificielle pour cr\xe9er des descriptions de biens qui captivent, pour segmenter des campagnes marketing qui atteignent l'acheteur id\xe9al et pour r\xe9aliser des analyses de march\xe9 pr\xe9cises. Ce n'est pas juste un gadget ; c'est la garantie que votre bien b\xe9n\xe9ficie d'une visibilit\xe9 maximale et est pr\xe9sent\xe9 \xe0 son meilleur prix.",de:"Ich gehe \xfcber das Traditionelle hinaus. Ich nutze die neuesten Werkzeuge der K\xfcnstlichen Intelligenz, um fesselnde Immobilienbeschreibungen zu erstellen, Marketingkampagnen zu segmentieren, die den idealen K\xe4ufer erreichen, und pr\xe4zise Marktanalysen durchzuf\xfchren. Das ist kein Gimmick; es ist die Garantie, dass Ihre Immobilie maximale Sichtbarkeit erh\xe4lt und zum besten Preis pr\xe4sentiert wird.",es:"Voy m\xe1s all\xe1 de lo tradicional. Utilizo las \xfaltimas herramientas de Inteligencia Artificial para crear descripciones de propiedades que cautivan, para segmentar campa\xf1as de marketing que llegan al comprador ideal y para realizar an\xe1lisis de mercado precisos. Esto no es solo un truco; es la garant\xeda de que su propiedad obtiene la m\xe1xima visibilidade y se presenta a su melhor precio.",zh:"我超越传统。我利用最新的人工智能工具来撰写引人入胜的房产描述，精准定位营销活动以触达理想买家，并进行精确的市场分析。这不仅仅是噱头，而是确保您的房产获得最大曝光并以最优价格呈现的保证。"},about_distinction_2_title:{pt:"Transpar\xeancia Total",en:"Total Transparency",fr:"Transparence Totale",de:"Vollst\xe4ndige Transparenz",es:"Transparencia Total",zh:"完全透明"},about_distinction_2_desc:{pt:"Acredito que a confian\xe7a \xe9 a base de qualquer bom neg\xf3cio. Por isso, comprometo-me a uma comunica\xe7\xe3o 100% transparente. Ter\xe1 acesso a relat\xf3rios detalhados sobre as visitas e o interesse no seu im\xf3vel, e ouvir\xe1 sempre de mim uma avalia\xe7\xe3o honesta, mesmo que n\xe3o seja o que espera ouvir. O meu foco \xe9 o seu melhor interesse, n\xe3o a venda a qualquer custo.",en:"I believe that trust is the foundation of any good business. That's why I commit to 100% transparent communication. You will have access to detailed reports on visits and interest in your property, and you will always hear an honest assessment from me, even if it's not what you expect to hear. My focus is your best interest, not selling at any cost.",fr:"Je crois que la confiance est la base de toute bonne affaire. C'est pourquoi je m'engage \xe0 une communication 100% transparente. Vous aurez acc\xe8s \xe0 des rapports d\xe9taill\xe9s sur les visites et l'int\xe9r\xeat pour votre bien, et vous entendrez toujours de ma part une \xe9valuation honn\xeate, m\xeame si ce n'est pas ce que vous attendez. Mon objectif est votre meilleur int\xe9r\xeat, pas la vente \xe0 tout prix.",de:"Ich glaube, dass Vertrauen die Grundlage jedes guten Gesch\xe4fts ist. Deshalb verpflichte ich mich zu 100% transparenter Kommunikation. Sie erhalten Zugang zu detaillierten Berichten \xfcber Besichtigungen und das Interesse an Ihrer Immobilie und h\xf6ren von mir immer eine ehrliche Einsch\xe4tzung, auch wenn es nicht das ist, was Sie erwarten. Mein Fokus liegt auf Ihrem besten Interesse, nicht auf dem Verkauf um jeden Preis.",es:"Creo que la confianza es la base de cualquier buen negocio. Por eso, me comprometo a una comunicaci\xf3n 100% transparente. Tendr\xe1 acceso a informes detallados sobre las visitas y el inter\xe9s en su propiedad, y siempre escuchar\xe1 de m\xed una evaluaci\xf3n honesta, incluso si no es lo que espera o\xedr. Mi enfoque es su melhor inter\xe9s, n\xe3o la venta a cualquier coste.",zh:"我相信信任是任何成功商业合作的基石。因此，我承诺进行100%透明的沟通。您将可以查阅关于您房产的访问量和关注度的详细报告，并且总能从我这里听到诚实的评估，即使那不是您所期望听到的。我的焦点是您的最大利益，而不是不计代价地完成销售。"},about_distinction_3_title:{pt:"Mentalidade de Investidor",en:"Investor Mindset",fr:"Mentalit\xe9 d'Investisseur",de:"Investoren-Mentalit\xe4t",es:"Mentalidad de Inversor",zh:"投资者思维"},about_distinction_3_desc:{pt:"N\xe3o vejo um im\xf3vel apenas como uma casa; vejo-o como um ativo. A minha paix\xe3o pelo mercado \xe9 tamb\xe9m a de um investidor. Por isso, analiso cada neg\xf3cio com o mesmo rigor que aplicaria ao meu pr\xf3prio portf\xf3lio. Procuro o melhor retorno para si, seja na venda pelo pre\xe7o m\xe1ximo ou na compra de uma propriedade com verdadeiro potencial de valoriza\xe7\xe3o.",en:"I don't just see a property as a house; I see it as an asset. My passion for the market is also that of an investor. Therefore, I analyze each deal with the same rigor I would apply to my own portfolio. I seek the best return for you, whether it's selling at the maximum price or buying a property with true appreciation potential.",fr:"Je ne vois pas un bien immobilier seulement como une maison ; je le vois comme un actif. Ma passion pour le march\xe9 est aussi celle d'un investisseur. C'est pourquoi j'analyse chaque transaction avec la m\xeame rigueur que j'appliquerais \xe0 mon propre portefeuille. Je recherche le meilleur retour sur investissement pour vous, que ce soit en vendant au prix maximum ou en achetant une propri\xe9t\xe9 avec un r\xe9el potentiel de valorisation.",de:"Ich sehe eine Immobilie nicht nur als ein Haus; ich sehe sie als eine Anlage. Meine Leidenschaft f\xfcr den Markt ist auch die eines Investors. Daher analysiere ich jedes Gesch\xe4ft mit der gleichen Strenge, die ich auf mein eigenes Portfolio anwenden w\xfcrde. Ich strebe den besten Ertrag f\xfcr Sie an, sei es durch den Verkauf zum H\xf6chstpreis oder den Kauf einer Immobilie mit echtem Wertsteigerungspotenzial.",es:"No veo una propiedad solo como una casa; la veo como un activo. Mi pasi\xf3n por el mercado es tambi\xe9n la de un inversor. Por lo tanto, analizo cada operaci\xf3n con el mismo rigor que aplicar\xeda a mi propia cartera. Busco el mejor rendimiento para usted, ya sea vendiendo al precio m\xe1ximo o comprando una propiedad con verdadero potencial de revalorizaci\xf3n.",zh:"我不只把房产看作一个家，我视其为一项资产。我对市场的热情也源于我作为一名投资者的身份。因此，我以审视自己投资组合的严格标准来分析每一笔交易。我为您寻求最佳回报，无论是通过以最高价出售，还是购买具有真正升值潜力的房产。"},about_cta:{pt:"Se procura energia inesgot\xe1vel e uma abordagem moderna para vender ou comprar a sua casa, estou pronto para trabalhar por si.",en:"If you are looking for endless energy and a modern approach to selling or buying your home, I am ready to work for you.",fr:"Si vous recherchez une \xe9nergie in\xe9puisable et une approche moderne pour vendre ou acheter votre maison, je suis pr\xeat \xe0 travailler pour vous.",de:"Wenn Sie unersch\xf6pfliche Energie und einen modernen Ansatz f\xfcr den Verkauf oder Kauf Ihres Hauses suchen, bin ich bereit, f\xfcr Sie zu arbeiten.",es:"Si busca una energ\xeda inagotable y un enfoque moderno para vender o comprar su casa, estoy listo para trabajar para usted.",zh:"如果您在买卖房产的过程中寻求无限的活力和现代化的方法，我已准备好为您服务。"},about_cta_link:{pt:"estou pronto para trabalhar por si.",en:"I am ready to work for you.",fr:"je suis pr\xeat \xe0 travailler pour vous.",de:"bin ich bereit, f\xfcr Sie zu arbeiten.",es:"estoy listo para trabajar para usted.",zh:"我已准备好为您服务。"},golden_tips_main_title:{pt:"Dicas de Ouro",en:"Golden Nuggets",fr:"Conseils d'Or",de:"Goldene Tipps",es:"Consejos de Oro",zh:"金玉良言"},golden_tips_subtitle:{pt:"Artigos e novidades sobre o mercado imobili\xe1rio.",en:"Tips and news about the Portuguese real estate market.",fr:"Conseils et actualit\xe9s sur le march\xe9 immobilier portugais.",de:"Tipps und Neuigkeiten \xfcber den portugiesischen Immobilienmarkt.",es:"Consejos y noticias sobre el mercado inmobiliario portugu\xe9s.",zh:"关于葡萄牙房地产市场的技巧和新闻。"},golden_tips_post_1_title:{pt:"Como poupar mais de 10.000€ na compra da primeira casa",en:"How to save over €10,000 on your first home purchase",fr:"Comment \xe9conomiser plus de 10 000 € sur l'achat de votre premi\xe8re maison",de:"Wie Sie beim Kauf Ihres ersten Eigenheims \xfcber 10.000 € sparen k\xf6nnen",es:"C\xf3mo ahorrar m\xe1s de 10.000 € en la compra de su primera vivienda",zh:"首次购房如何节省超过10,000欧元"},golden_tips_post_1_excerpt:{pt:"Se tens menos de 35 anos, descobre como as novas medidas de 2026 te podem ajudar a poupar milhares em impostos.",en:"If you are under 35, find out how the new 2026 measures can help you save thousands in taxes.",fr:"Si vous avez moins de 35 ans, d\xe9couvrez comment les nouvelles mesures de 2026 peuvent vous aider \xe0 \xe9conomiser des milliers d'imp\xf4ts.",de:"Wenn Sie unter 35 sind, erfahren Sie, wie die neuen Ma\xdfnahmen von 2026 Ihnen helfen k\xf6nnen, Tausende an Steuern zu sparen.",es:"Si tienes menos de 35 a\xf1os, descubre c\xf3mo las nuevas medidas de 2026 pueden ayudarte a ahorrar miles en impuestos.",zh:"如果您未满35岁，了解2026年的新政策如何帮助您节省数千欧元的税款。"},golden_tips_post_2_title:{pt:"Cr\xe9dito Habita\xe7\xe3o: Comprar sozinho ou em casal?",en:"Mortgage: Buy alone or as a couple?",fr:"Cr\xe9dit immobilier : Acheter seul ou en couple ?",de:"Hypothek: Alleine oder als Paar kaufen?",es:"Hipoteca: \xbfComprar solo o en pareja?",zh:"房屋贷款：单独购买还是夫妻共同购买？"},golden_tips_post_2_excerpt:{pt:'Analisamos as vantagens de cada modalidade e a "rasteira" da avalia\xe7\xe3o banc\xe1ria que pode colocar o seu neg\xf3cio em risco.',en:'We analyze the pros of each option and the "pitfall" of bank appraisal that can put your deal at risk.',fr:'Nous analysons les avantages de chaque option et le "pi\xe8ge" de l\'\xe9valuation bancaire qui peut mettre votre transaction en p\xe9ril.',de:"Wir analysieren die Vorteile jeder Option und die „Falle“ der Bankbewertung, die Ihr Gesch\xe4ft gef\xe4hrden kann.",es:'Analizamos las ventajas de cada opci\xf3n y el "escollo" de la tasaci\xf3n bancaria que puede poner en riesgo su operaci\xf3n.',zh:"我们分析了每种选择的利弊，以及可能危及您交易的银行评估“陷阱”。"},golden_tips_post_3_title:{pt:"5 Erros que Impedem a Venda do seu Im\xf3vel em Lisboa",en:"5 Marketing Mistakes That Prevent the Sale of Your Property in Lisbon",fr:"5 Erreurs Marketing qui Emp\xeachent la Vente de Votre Bien \xe0 Lisbonne",de:"5 Marketingfehler, die den Verkauf Ihrer Immobilie in Lissabon verhindern",es:"5 errores de marketing que impiden la venta de su propiedad en Lisboa",zh:"导致您在里斯本的房产无法售出的5个营销错误"},golden_tips_post_3_excerpt:{pt:"Descubra porque \xe9 que alguns an\xfancios s\xe3o ignorados. Da fotografia \xe0 segmenta\xe7\xe3o, veja os erros que desvalorizam o seu im\xf3vel.",en:"Find out why some listings are ignored. From photography to targeting, see the mistakes that devalue your property.",fr:"D\xe9couvrez pourquoi certaines annonces sont ignor\xe9es. De la photographie au ciblage, d\xe9couvrez les erreurs qui d\xe9valuent votre bien.",de:"Finden Sie heraus, warum einige Angebote ignoriert werden. Von der Fotografie bis zur Zielgruppenansprache, sehen Sie die Fehler, die Ihre Immobilie entwerten.",es:"Descubra por qu\xe9 se ignoran algunos anuncios. Desde la fotograf\xeda hasta la segmentaci\xf3n, vea los errores que deval\xfaan su propiedad.",zh:"了解为什么有些房源会被忽视。从摄影到目标客户定位，看看那些让您房产贬值的错误。"},golden_tips_post_4_title:{pt:"Trespasse de Neg\xf3cio: O Guia para N\xe3o Cometer Erros",en:"Business Transfer: The Guide to Avoiding Mistakes",fr:"Cession de fonds de commerce : Le guide pour \xe9viter les erreurs",de:"Gesch\xe4fts\xfcbertragung: Der Leitfaden zur Fehlervermeidung",es:"Traspaso de negocio: La gu\xeda para no cometer errores",zh:"商业转让：避免错误的指南"},golden_tips_post_4_excerpt:{pt:"Decidir passar o testemunho de um neg\xf3cio \xe9 uma decis\xe3o estrat\xe9gica. Saiba como evitar erros comuns e maximizar o valor do seu trespasse.",en:"Passing on a business is a strategic decision. Learn how to avoid common mistakes and maximize the value of your transfer.",fr:"Transmettre une entreprise est une d\xe9cision strat\xe9gique. Apprenez \xe0 \xe9viter les erreurs courantes et \xe0 maximiser la valeur de votre cession.",de:"Ein Unternehmen weiterzugeben ist eine strategische Entscheidung. Erfahren Sie, wie Sie h\xe4ufige Fehler vermeiden und den Wert Ihrer \xdcbertragung maximieren.",es:"Traspasar un negocio es una decisi\xf3n estrat\xe9gica. Aprenda a evitar errores comunes y a maximizar el valor de su traspaso.",zh:"转让业务是一项战略决策。了解如何避免常见错误并最大化您的转让价值。"},golden_tips_post_5_title:{pt:"Exclusividade: Funciona no amor, funciona na venda da sua casa.",en:"Exclusivity: It works in love, it works when selling your home.",fr:"Exclusivit\xe9 : \xc7a marche en amour, \xe7a marche pour la vente de votre maison.",de:"Exklusivit\xe4t: Es funktioniert in der Liebe, es funktioniert beim Verkauf Ihres Hauses.",es:"Exclusividad: Funciona en el amor, funciona al vender tu casa.",zh:"独家代理：既适用于爱情，也适用于卖房。"},golden_tips_post_5_excerpt:{pt:'Vender uma casa em "regime aberto" \xe9 como um mau namoro. Descubra porque \xe9 que um compromisso de exclusividade valoriza o seu im\xf3vel.',en:'Selling a home on an "open listing" is like a bad relationship. Find out why an exclusive commitment adds value to your property.',fr:'Vendre une maison en "mandat simple" c\'est comme une mauvaise relation. D\xe9couvrez pourquoi un engagement exclusif valorise votre bien.',de:"Ein Haus mit einem „offenen Maklervertrag“ zu verkaufen, ist wie eine schlechte Beziehung. Finden Sie heraus, warum eine exklusive Bindung Ihre Immobilie aufwertet.",es:'Vender una casa con un "contrato abierto" es como una mala relaci\xf3n. Descubra por qu\xe9 un compromiso de exclusividade a\xf1ade valor a su propiedad.',zh:"以“开放式代理”出售房屋就像一段糟糕的恋情。了解为什么独家委托能为您的房产增值。"},golden_tips_post_6_title:{pt:"Os Melhores Bairros de Lisboa para Investir em 2026",en:"The Best Neighborhoods in Lisbon to Invest in 2026",fr:"Les Meilleurs Quartiers de Lisbonne pour Investir en 2026",de:"Die besten Stadtteile in Lissabon zum Investieren im Jahr 2026",es:"Los Mejores Barrios de Lisboa para Invertir en 2026",zh:"2026年里斯本最值得投资的社区"},golden_tips_post_6_excerpt:{pt:"No mercado imobili\xe1rio, os n\xfameros n\xe3o mentem. Se pretende investir em Lisboa, \xe9 fundamental analisar a evolu\xe7\xe3o m\xe9trica da cidade para compreender o potencial de retorno.",en:"In the real estate market, numbers don't lie. If you plan to invest in Lisbon, it is essential to analyze the city's metric evolution to understand the potential for return.",fr:"Sur le march\xe9 immobilier, les chiffres ne mentent pas. Si vous pr\xe9voyez d'investir \xe0 Lisbonne, il est essentiel d'analyser l'\xe9volution m\xe9trique de la ville pour comprendre le potentiel de retour.",de:"Auf dem Immobilienmarkt l\xfcgen Zahlen nicht. Wenn Sie in Lissabon investieren m\xf6chten, ist es unerl\xe4sslich, die metrische Entwicklung der Stadt zu analysieren, um das Renditepotenzial zu verstehen.",es:"En el mercado inmobiliario, los n\xfameros no mienten. Si planea invertir en Lisboa, es esencial analizar a evoluci\xf3n m\xe9trica de la ciudad para comprender o potencial de retorno.",zh:"在房地产市场，数字不会说谎。如果您计划在里斯本投资，分析城市的度量演变以了解回报潜力至关重要。"},golden_tips_coming_soon:{pt:"Mais artigos em breve.",en:"More articles coming soon.",fr:"Plus d'articles \xe0 venir.",de:"Weitere Artikel folgen in K\xfcrze.",es:"M\xe1s art\xedculos pr\xf3ximamente.",zh:"更多文章即将发布。"},golden_tips_coming_soon_card:{pt:"Em Breve",en:"Coming Soon",fr:"Bient\xf4t",de:"Demn\xe4chst",es:"Pr\xf3ximamente",zh:"即将推出"},evaluate_title:{pt:"Avalie o Seu Im\xf3vel",en:"Evaluate Your Property",fr:"\xc9valuez Votre Bien",de:"Bewerten Sie Ihre Immobilie",es:"Eval\xfae Su Propiedad",zh:"为您的房产估价"},evaluate_subtitle:{pt:"Descubra o valor do seu im\xf3vel em segundos com a nossa ferramenta.",en:"Discover the value of your property in seconds with our tool.",fr:"D\xe9couvrez la valeur de votre bien en quelques secondes avec notre outil.",de:"Entdecken Sie den Wert Ihrer Immobilie in Sekunden mit unserem Tool.",es:"Descubra el valor de su propiedad en segundos con nuestra herramienta.",zh:"使用我们的工具，在几秒钟内发现您房产的价值。"},terreno_title_wip:{pt:"P\xe1gina de Im\xf3vel",en:"Property Page",fr:"Page de la Propri\xe9t\xe9",de:"Immobilienseite",es:"P\xe1gina de la Propiedade",zh:"房产页面"},terreno_subtitle_wip:{pt:"Esta p\xe1gina estar\xe1 dispon\xedvel em breve.",en:"This page will be available soon.",fr:"Cette page sera bient\xf4t disponible.",de:"Diese Seite wird in K\xfcrze verf\xfcgbar sein.",es:"Esta p\xe1gina estar\xe1 disponible pronto.",zh:"此页面即将推出。"},post_poupar_title:{pt:"Como poupar mais de 10.000€ na compra da primeira casa sendo jovem (Guia 2026)",en:"How to save over €10,000 on your first home purchase as a young person (2026 Guide)",fr:"Comment \xe9conomiser plus de 10 000 € sur l'achat de votre premi\xe8re maison en tant que jeune (Guide 2026)",de:"Wie man als junger Mensch beim ersten Hauskauf \xfcber 10.000 € spart (Leitfaden 2026)",es:"C\xf3mo ahorrar m\xe1s de 10.000 € en la compra de tu primera casa siendo joven (Gu\xeda 2026)",zh:"年轻人首次购房如何节省超过10,000欧元（2026年指南）"},post_poupar_subtitle:{pt:"Se tens menos de 35 anos e est\xe1s a planear comprar a tua primeira casa em Portugal, as not\xedcias n\xe3o podiam ser melhores.",en:"If you are under 35 and planning to buy your first home in Portugal, the news couldn't be better.",fr:"Si vous avez moins de 35 ans et que vous pr\xe9voyez d'acheter votre premi\xe8re maison au Portugal, les nouvelles ne pourraient pas \xeatre meilleures.",de:"Wenn Sie unter 35 sind und planen, Ihr erstes Haus in Portugal zu kaufen, k\xf6nnten die Nachrichten nicht besser sein.",es:"Si tienes menos de 35 a\xf1os y est\xe1s planeando comprar tu primeira casa en Portugal, las noticias no podr\xedan ser mejores.",zh:"如果你未满35岁并计划在葡萄牙购买你的第一套房子，那么消息再好不过了。"},post_poupar_intro:{pt:"Em 2026, as medidas de apoio ao cr\xe9dito jovem permitem-te entrar no mercado imobili\xe1rio com uma poupan\xe7a que, em Lisboa, ultrapassa facilmente os 10.000€. Neste guia, explico-te como podes aproveitar estas isen\xe7\xf5es e quais as despesas que ainda tens de considerar.",en:"In 2026, youth credit support measures allow you to enter the real estate market with savings that, in Lisbon, easily exceed €10,000. In this guide, I explain how you can take advantage of these exemptions and what expenses you still need to consider.",fr:"En 2026, les mesures de soutien au cr\xe9dit pour les jeunes vous permettent d'entrer sur le march\xe9 immobilier avec des \xe9conomies qui, \xe0 Lisbonne, d\xe9passent facilement les 10 000 €. Dans ce guide, je vous explique comment profiter de ces exon\xe9rations et quelles d\xe9penses vous devez encore consid\xe9rer.",de:"Im Jahr 2026 erm\xf6glichen Ihnen die F\xf6rderma\xdfnahmen f\xfcr Jugendkredite den Eintritt in den Immobilienmarkt mit Einsparungen, die in Lissabon leicht 10.000 € \xfcbersteigen. In diesem Leitfaden erkl\xe4re ich, wie Sie diese Befreiungen nutzen k\xf6nnen und welche Ausgaben Sie noch ber\xfccksichtigen m\xfcssen.",es:"En 2026, las medidas de apoyo al cr\xe9dito joven te permiten entrar en el mercado inmobiliario con un ahorro que, en Lisboa, supera f\xe1cilmente los 10.000 €. En esta gu\xeda, te explico c\xf3mo puedes aprovechar estas exenciones y qu\xe9 gastos todav\xeda tienes que considerar.",zh:"到2026年，青年信贷支持措施将让你能够进入房地产市场，并在里斯本轻松节省超过10,000欧元。在本指南中，我将解释如何利用这些豁免政策，以及你仍需考虑哪些费用。"},post_poupar_h2_1:{pt:"1. O Grande Truque: Isen\xe7\xe3o de IMT e Selo",en:"1. The Big Trick: IMT and Stamp Duty Exemption",fr:"1. La grande astuce : Exon\xe9ration de l'IMT et du droit de timbre",de:"1. Der gro\xdfe Trick: Befreiung von IMT und Stempelsteuer",es:"1. El Gran Truco: Exenci\xf3n de IMT y del Impuesto de Actos Jur\xeddicos Documentados",zh:"1. 大技巧：IMT和印花税豁免"},post_poupar_p1:{pt:'A maior fatia da poupan\xe7a vem da isen\xe7\xe3o de dois impostos que, at\xe9 h\xe1 pouco tempo, "comiam" as poupan\xe7as de qualquer jovem.',en:'The biggest part of the savings comes from the exemption of two taxes that, until recently, "ate up" the savings of any young person.',fr:"La plus grande partie des \xe9conomies provient de l'exon\xe9ration de deux imp\xf4ts qui, jusqu'\xe0 r\xe9cemment, \xab d\xe9voraient \xbb les \xe9conomies de tout jeune.",de:"Der gr\xf6\xdfte Teil der Ersparnisse stammt aus der Befreiung von zwei Steuern, die bis vor kurzem die Ersparnisse jedes jungen Menschen „auffra\xdfen“.",es:'La maior parte del ahorro proviene de la exenci\xf3n de dos impuestos que, hasta hace poco, "se com\xedan" los ahorros de cualquier joven.',zh:"节省的最大部分来自两种税收的豁免，直到最近，这两种税收还“吞噬”了任何年轻人的储蓄。"},post_poupar_li1_strong:{pt:"IMT Jovem:",en:"Youth IMT:",fr:"IMT Jeune :",de:"Jugend-IMT:",es:"IMT Joven:",zh:"青年IMT："},post_poupar_li1_text:{pt:"Se comprares uma casa para habita\xe7\xe3o pr\xf3pria e permanente (HPP) at\xe9 330.539€, n\xe3o pagas nem um c\xeantimo de IMT.",en:"If you buy a house for your own permanent residence (HPP) up to €330,539, you don't pay a single cent of IMT.",fr:"Si vous achetez une maison pour votre r\xe9sidence principale et permanente (HPP) jusqu'\xe0 330 539 €, vous ne payez pas un seul centime d'IMT.",de:"Wenn Sie ein Haus f\xfcr Ihren st\xe4ndigen Wohnsitz (HPP) bis zu 330.539 € kaufen, zahlen Sie keinen einzigen Cent IMT.",es:"Si compras una casa para tu pr\xf3pria residencia permanente (HPP) de hasta 330.539 €, no pagas ni un c\xeantimo de IMT.",zh:"如果您购买一栋价值高达330,539欧元的自住永久性住宅（HPP），您无需支付一分钱的IMT。"},post_poupar_li2_strong:{pt:"Imposto do Selo de Aquisi\xe7\xe3o:",en:"Acquisition Stamp Duty:",fr:"Droit de Timbre d'Acquisition :",de:"Erwerbsstempelsteuer:",es:"Impuesto de Actos Jur\xeddicos Documentados de Adquisici\xf3n:",zh:"购置印花税："},post_poupar_li2_text:{pt:"Est\xe1s tamb\xe9m isento da taxa de 0,8% sobre o valor da casa (at\xe9 ao mesmo limite de valor).",en:"You are also exempt from the 0.8% rate on the value of the house (up to the same value limit).",fr:"Vous \xeates \xe9galement exon\xe9r\xe9 du taux de 0,8 % sur la valeur de la maison (jusqu'\xe0 la m\xeame limite de valeur).",de:"Sie sind auch von der 0,8%-igen Steuer auf den Wert des Hauses (bis zur gleichen Wertgrenze) befreit.",es:"Tambi\xe9n est\xe1s exento de la tasa del 0,8% sobre el valor de la casa (hasta el mesmo l\xedmite de valor).",zh:"您还可免缴房屋价值0.8%的税率（最高至相同价值上限）。"},post_poupar_p2:{pt:"Para uma casa de 300.000€, isto significa uma poupan\xe7a direta de cerca de 12.940€ logo \xe0 cabe\xe7a!",en:"For a €300,000 house, this means a direct saving of about €12,940 right from the start!",fr:"Pour une maison de 300 000 €, cela signifie une \xe9conomie directe d'environ 12 940 € d\xe8s le d\xe9part !",de:"F\xfcr ein 300.000-Euro-Haus bedeutet das eine direkte Ersparnis von rund 12.940 € von Anfang an!",es:"Para una casa de 300.000 €, \xa1esto significa un ahorro directo de unos 12.940 € desde el principio!",zh:"对于一栋价值30万欧元的房子来说，这意味着从一开始就可以直接节省约12,940欧元！"},post_poupar_h2_2:{pt:"2. Que despesas ainda tens de pagar?",en:"2. What expenses do you still have to pay?",fr:"2. Quelles d\xe9penses vous reste-t-il \xe0 payer ?",de:"2. Welche Ausgaben m\xfcssen Sie noch bezahlen?",es:"2. \xbfQu\xe9 gastos te quedan por pagar?",zh:"2. 你还需要支付哪些费用？"},post_poupar_p3:{pt:'Mesmo com as isen\xe7\xf5es, o "custo zero" n\xe3o existe. Como jovem comprador, ainda ter\xe1s de prever:',en:'Even with the exemptions, "zero cost" does not exist. As a young buyer, you will still have to budget for:',fr:"M\xeame avec les exon\xe9rations, le \xab co\xfbt z\xe9ro \xbb n'existe pas. En tant que jeune acheteur, vous devrez encore pr\xe9voir :",de:"Auch mit den Befreiungen gibt es keine „Nullkosten“. Als junger K\xe4ufer m\xfcssen Sie noch Folgendes budgetieren:",es:'Incluso con las exenciones, el "coste cero" no existe. Como comprador joven, todav\xeda tendr\xe1s que presupuestar para:',zh:"即使有豁免，“零成本”也并不存在。作为年轻买家，你仍需为以下事项做预算："},post_poupar_li3_strong:{pt:"Imposto do Selo sobre o Cr\xe9dito:",en:"Stamp Duty on Credit:",fr:"Droit de Timbre sur le Cr\xe9dit :",de:"Stempelsteuer auf Kredite:",es:"Impuesto de Actos Jur\xeddicos Documentados sobre el Cr\xe9dito:",zh:"信贷印花税："},post_poupar_li3_text:{pt:"Se pedires financiamento ao banco, o Estado cobra 0,6% sobre o valor emprestado.",en:"If you apply for financing from the bank, the State charges 0.6% on the borrowed amount.",fr:"Si vous demandez un financement \xe0 la banque, l'\xc9tat facture 0,6 % sur le montant emprunt\xe9.",de:"Wenn Sie eine Finanzierung bei der Bank beantragen, erhebt der Staat 0,6 % auf den geliehenen Betrag.",es:"Si solicitas financiaci\xf3n al banco, el Estado cobra un 0,6% sobre el importe prestado.",zh:"如果你向银行申请融资，国家将对借款金额征收0.6%的费用。"},post_poupar_li4_strong:{pt:"Escritura e Registos:",en:"Deed and Registration:",fr:"Acte Notari\xe9 et Enregistrements :",de:"Urkunde und Registrierung:",es:"Escritura y Registros:",zh:"契约和注册："},post_poupar_li4_text:{pt:"Os custos com o not\xe1rio e o registo da casa na Conservat\xf3ria variam entre 400€ a 800€.",en:"The costs with the notary and the registration of the house at the Land Registry Office range from €400 to €800.",fr:"Les frais de notaire et d'enregistrement de la maison au bureau du cadastre varient de 400 € \xe0 800 €.",de:"Die Kosten f\xfcr den Notar und die Registrierung des Hauses beim Grundbuchamt liegen zwischen 400 € und 800 €.",es:"Los costes con el notario y el registro de la casa en el Registro de la Propiedad oscilan entre 400 € y 800 €.",zh:"公证人和在土地注册处的房屋注册费用在400欧元到800欧元之间。"},post_poupar_li5_strong:{pt:"Custos Banc\xe1rios:",en:"Bank Costs:",fr:"Frais Bancaires :",de:"Bankkosten:",es:"Costes Bancarios:",zh:"银行成本："},post_poupar_li5_text:{pt:"Comiss\xf5es de avalia\xe7\xe3o e abertura de processo (m\xe9dia de 700€).",en:"Appraisal and application processing fees (average of €700).",fr:"Commissions d'\xe9valuation et de montage de dossier (en moyenne 700 €).",de:"Bewertungs- und Antragsbearbeitungsgeb\xfchren (durchschnittlich 700 €).",es:"Comisiones de tasaci\xf3n y tramitaci\xf3n de la solicitud (media de 700 €).",zh:"评估和申请处理费（平均700欧元）。"},post_poupar_h3_1:{pt:"Exemplo Real: Compra de um im\xf3vel de 300.000€ em Lisboa",en:"Real Example: Purchase of a €300,000 property in Lisbon",fr:"Exemple R\xe9el : Achat d'un bien de 300 000 € \xe0 Lisbonne",de:"Echtes Beispiel: Kauf einer Immobilie f\xfcr 300.000 € in Lissabon",es:"Ejemplo Real: Compra de una propiedad de 300.000 € en Lisboa",zh:"真实案例：在里斯本购买价值30万欧元的房产"},post_poupar_p4:{pt:"V\xea a diferen\xe7a entre um comprador jovem (com benef\xedcios) e um comprador acima dos 35 anos:",en:"See the difference between a young buyer (with benefits) and a buyer over 35:",fr:"Voyez la diff\xe9rence entre un jeune acheteur (avec avantages) et un acheteur de plus de 35 ans :",de:"Sehen Sie den Unterschied zwischen einem jungen K\xe4ufer (mit Vorteilen) und einem K\xe4ufer \xfcber 35:",es:"Vea la diferencia entre un comprador joven (con beneficios) y un comprador maior de 35 a\xf1os:",zh:"看看年轻买家（有福利）和35岁以上买家之间的区别："},table_header_expense:{pt:"Despesa",en:"Expense",fr:"D\xe9pense",de:"Ausgabe",es:"Gasto",zh:"费用"},table_header_young:{pt:"Jovem at\xe9 35 anos",en:"Younger than 35",fr:"Moins de 35 ans",de:"J\xfcnger als 35",es:"Menor de 35 a\xf1os",zh:"35岁以下"},table_header_over35:{pt:"Comprador > 35 anos",en:"Buyer > 35",fr:"Acheteur > 35 ans",de:"K\xe4ufer > 35",es:"Comprador > 35 a\xf1os",zh:"35岁以上买家"},table_row1_expense:{pt:"IMT (Imposto)",en:"IMT (Tax)",fr:"IMT (Imp\xf4t)",de:"IMT (Steuer)",es:"IMT (Impuesto)",zh:"IMT（税）"},table_row1_young:{pt:"0€",en:"€0",fr:"0 €",de:"0 €",es:"0 €",zh:"0欧元"},table_row1_over35:{pt:"10.540€",en:"€10,540",fr:"10 540 €",de:"10.540 €",es:"10.540 €",zh:"10,540欧元"},table_row2_expense:{pt:"I. Selo (sobre a compra)",en:"Stamp Duty (on purchase)",fr:"Droit de Timbre (sur l'achat)",de:"Stempelsteuer (beim Kauf)",es:"Impuesto de Actos Jur\xeddicos Documentados (sobre la compra)",zh:"印花税（购买时）"},table_row2_young:{pt:"0€",en:"€0",fr:"0 €",de:"0 €",es:"0 €",zh:"0欧元"},table_row2_over35:{pt:"2.400€",en:"€2,400",fr:"2 400 €",de:"2.400 €",es:"2.400 €",zh:"2,400欧元"},table_row3_expense:{pt:"I. Selo (sobre o cr\xe9dito)",en:"Stamp Duty (on credit)",fr:"Droit de Timbre (sur le cr\xe9dit)",de:"Stempelsteuer (auf Kredit)",es:"Impuesto de Actos Jur\xeddicos Documentados (sobre le cr\xe9dito)",zh:"印花税（信贷）"},table_row3_young:{pt:"1.620€",en:"€1,620",fr:"1 620 €",de:"1.620 €",es:"1.620 €",zh:"1,620欧元"},table_row3_over35:{pt:"1.620€",en:"€1,620",fr:"1 620 €",de:"1.620 €",es:"1.620 €",zh:"1,620欧元"},table_row4_expense:{pt:"Escritura e Registos",en:"Deed and Registrations",fr:"Acte et Enregistrements",de:"Urkunde und Eintragungen",es:"Escritura y Registros",zh:"契约和注册"},table_row4_young:{pt:"800€",en:"€800",fr:"800 €",de:"800 €",es:"800 €",zh:"800欧元"},table_row4_over35:{pt:"800€",en:"€800",fr:"800 €",de:"800 €",es:"800 €",zh:"800欧元"},table_row5_expense:{pt:"Comiss\xf5es Banc\xe1rias",en:"Bank Fees",fr:"Frais Bancaires",de:"Bankgeb\xfchren",es:"Comisiones Bancarias",zh:"银行费用"},table_row5_young:{pt:"750€",en:"€750",fr:"750 €",de:"750 €",es:"750 €",zh:"750欧元"},table_row5_over35:{pt:"750€",en:"€750",fr:"750 €",de:"750 €",es:"750 €",zh:"750欧元"},table_total_expense:{pt:"TOTAL A PAGAR",en:"TOTAL TO PAY",fr:"TOTAL \xc0 PAYER",de:"GESAMT ZU ZAHLEN",es:"TOTAL A PAGAR",zh:"总计支付"},table_total_young:{pt:"3.170€",en:"€3,170",fr:"3 170 €",de:"3.170 €",es:"3.170 €",zh:"3,170欧元"},table_total_over35:{pt:"16.110€",en:"€16,110",fr:"16 110 €",de:"16.110 €",es:"16.110 €",zh:"16,110欧元"},post_poupar_savings:{pt:"A tua poupan\xe7a total: 12.940€",en:"Your total savings: €12,940",fr:"Vos \xe9conomies totales : 12 940 €",de:"Ihre Gesamtersparnis: 12.940 €",es:"Tu ahorro total: 12.940 €",zh:"您的总节省额：12,940欧元"},post_poupar_h2_3:{pt:"3. E a entrada? (Garantia P\xfablica)",en:"3. What about the down payment? (Public Guarantee)",fr:"3. Et l'acompte ? (Garantie Publique)",de:"3. Und was ist mit der Anzahlung? (\xd6ffentliche Garantie)",es:"3. \xbfY el pago inicial? (Garant\xeda P\xfablica)",zh:"3. 首付款呢？（公共担保）"},post_poupar_p5:{pt:"Al\xe9m da poupan\xe7a nos impostos, se n\xe3o tiveres os 10% de entrada (os habituais 30.000€ para uma casa deste valor), em 2026 podes recorrer \xe0 Garantia P\xfablica. Esta medida permite que o banco te financie a 100% do valor da casa, desde que cumpras os crit\xe9rios de rendimento e idade.",en:"In addition to tax savings, if you don't have the 10% down payment (the usual €30,000 for a house of this value), in 2026 you can resort to the Public Guarantee. This measure allows the bank to finance you 100% of the value of the house, as long as you meet the income and age criteria.",fr:"En plus des \xe9conomies d'imp\xf4ts, si vous n'avez pas l'acompte de 10 % (les 30 000 € habituels pour une maison de cette valeur), en 2026, vous pouvez recourir \xe0 la Garantie Publique. Cette mesure permet \xe0 la banque de vous financer \xe0 100 % de la valeur de la maison, \xe0 condition que vous remplissiez les crit\xe8res de revenus et d'\xe2ge.",de:"Zus\xe4tzlich zu den Steuerersparnissen k\xf6nnen Sie 2026, wenn Sie nicht \xfcber die 10 % Anzahlung (die \xfcblichen 30.000 € f\xfcr ein Haus dieses Wertes) verf\xfcgen, die \xf6ffentliche Garantie in Anspruch nehmen. Diese Ma\xdfnahme erm\xf6glicht es der Bank, Ihnen 100 % des Wertes des Hauses zu finanzieren, sofern Sie die Einkommens- und Alterskriterien erf\xfcllen.",es:"Adem\xe1s del ahorro fiscal, si no tienes el 10% de entrada (los 30.000 € habituales para una casa de este valor), en 2026 puedes recurrir a la Garant\xeda P\xfablica. Esta medida permite que el banco te financie el 100% del valor de la casa, siempre que cumplas los criterios de ingresos y edad.",zh:"除了税收节省外，如果你没有10%的首付款（对于这种价值的房子通常是30,000欧元），到2026年，你可以求助于公共担保。只要你符合收入和年龄标准，这项措施允许银行为你提供房屋价值100%的融资。"},post_poupar_h2_4:{pt:"Conclus\xe3o: N\xe3o deixes dinheiro na mesa",en:"Conclusion: Don't leave money on the table",fr:"Conclusion : Ne laissez pas d'argent sur la table",de:"Fazit: Lassen Sie kein Geld auf dem Tisch liegen",es:"Conclusi\xf3n: No dejes dinero sobre la mesa",zh:"结论：不要让钱白白溜走"},post_poupar_p6:{pt:"Comprar a primeira casa em Lisboa \xe9 um desafio, mas em 2026 as condi\xe7\xf5es s\xe3o historicamente favor\xe1veis para os jovens. No entanto, o processo banc\xe1rio pode ser complexo e cada caso \xe9 um caso.",en:"Buying a first home in Lisbon is a challenge, but in 2026 the conditions are historically favorable for young people. However, the banking process can be complex and each case is unique.",fr:"Acheter une premi\xe8re maison \xe0 Lisbonne est un d\xe9fi, mais en 2026, les conditions sont historiquement favorables pour les jeunes. Cependant, le processus bancaire peut \xeatre complexe et chaque cas est unique.",de:"Der Kauf eines ersten Eigenheims in Lissabon ist eine Herausforderung, aber 2026 sind die Bedingungen f\xfcr junge Menschen historisch g\xfcnstig. Der Bankprozess kann jedoch komplex sein und jeder Fall ist einzigartig.",es:"Comprar una primeira casa en Lisboa es un desaf\xedo, pero en 2026 las condiciones son hist\xf3ricamente favorables para los j\xf3venes. Sin embargo, el processo banc\xe1rio puede ser complejo y cada caso es \xfanico.",zh:"在里斯本购买第一套房子是一个挑战，但在2026年，对年轻人来说条件是历史上最有利的。然而，银行流程可能很复杂，每个案例都是独特的。"},post_poupar_cta_title:{pt:"Quer saber exatamente quanto pode poupar e se \xe9 eleg\xedvel para estas isen\xe7\xf5es?",en:"Want to know exactly how much you can save and if you are eligible for these exemptions?",fr:"Vous voulez savoir exactement combien vous pouvez \xe9conomiser et si vous \xeates \xe9ligible \xe0 ces exon\xe9rations ?",de:"M\xf6chten Sie genau wissen, wie viel Sie sparen k\xf6nnen und ob Sie f\xfcr diese Befreiungen anspruchsberechtigt sind?",es:"\xbfQuieres saber exactamente cu\xe1nto puedes ahorrar y si eres elegible para estas exenciones?",zh:"想确切知道你能节省多少钱以及你是否有资格享受这些豁免吗？"},post_poupar_cta_p1:{pt:"N\xe3o precisa de fazer estas contas sozinho. Trabalhamos com parceiros de intermedia\xe7\xe3o de cr\xe9dito especializados que o ajudam a perceber todo o seu potencial de poupan\xe7a e a encontrar o melhor financiamento no mercado.",en:"You don't have to do these calculations alone. We work with specialized credit intermediation partners who help you understand your full savings potential and find the best financing on the market.",fr:"Vous n'avez pas \xe0 faire ces calculs vous-m\xeame. Nous travaillons avec des partenaires d'interm\xe9diation de cr\xe9dit sp\xe9cialis\xe9s qui vous aident \xe0 comprendre tout votre potentiel d'\xe9conomies et \xe0 trouver le meilleur financement sur le march\xe9.",de:"Sie m\xfcssen diese Berechnungen nicht alleine durchf\xfchren. Wir arbeiten mit spezialisierten Kreditvermittlungspartnern zusammen, die Ihnen helfen, Ihr volles Sparpotenzial zu verstehen und die beste Finanzierung auf dem Markt zu finden.",es:"No tienes que hacer estos c\xe1lculos solo. Trabajamos con socios de intermediaci\xf3n de cr\xe9dito especializados que te ayudan a comprender todo tu potencial de ahorro y a encontrar la mejor financiaci\xf3n del mercado.",zh:"您不必独自进行这些计算。我们与专业的信贷中介合作伙伴合作，他们可以帮助您了解您的全部储蓄潜力，并找到市场上最佳的融资方案。"},post_poupar_cta_p2:{pt:"Este servi\xe7o \xe9 totalmente gratuito para si e pode poupar-lhe meses de burocracia.",en:"This service is completely free for you and can save you months of bureaucracy.",fr:"Ce service est enti\xe8rement gratuit pour vous et peut vous faire \xe9conomiser des mois de bureaucratie.",de:"Dieser Service ist f\xfcr Sie v\xf6llig kostenlos und kann Ihnen Monate an B\xfcrokratie ersparen.",es:"Este servicio es completamente gratuito para usted y puede ahorrarle meses de burocracia.",zh:"这项服务对您完全免费，可以为您节省数月的官僚程序。"},post_poupar_cta_button:{pt:"Falar com um especialista",en:"Talk to an expert",fr:"Parler \xe0 un expert",de:"Sprechen Sie mit einem Experten",es:"Hable con un experto",zh:"与专家交谈"},post_credito_main_title:{pt:"Cr\xe9dito Habita\xe7\xe3o: Comprar sozinho ou em casal?",en:"Mortgage: Buying alone or as a couple?",fr:"Cr\xe9dit immobilier : Acheter seul ou en couple ?",de:"Immobilienkredit: Alleine oder als Paar kaufen?",es:"Hipoteca: \xbfComprar solo o en pareja?",zh:"住房贷款：独自购买还是夫妻共同购买？"},post_credito_subtitle:{pt:"Analisamos as vantagens de cada modalidade e os riscos envolvidos no financiamento.",en:"We analyze the advantages of each option and the risks involved in financing.",fr:"Nous analysons les avantages de chaque option et les risques li\xe9s au financement.",de:"Wir analysieren die Vorteile jeder Option und die mit der Finanzierung verbundenen Risiken.",es:"Analizamos las ventajas de cada opci\xf3n y los riesgos involucrados en la financiaci\xf3n.",zh:"我们分析了每种选择的优势以及融资涉及的风险。"},post_credito_intro:{pt:"A decis\xe3o de comprar casa \xe9 um dos marcos financeiros mais importantes da vida. Mas deve faz\xea-lo sozinho ou acompanhado?",en:"The decision to buy a home is one of life's most important financial milestones. But should you do it alone or accompanied?",fr:"La d\xe9cision d'acheter une maison est l'une des \xe9tapes financi\xe8res les plus importantes de la vie. Mais devriez-vous le faire seul ou accompagn\xe9 ?",de:"Die Entscheidung, ein Haus zu kaufen, ist eine der wichtigsten finanziellen Meilensteine im Leben. Aber sollten Sie es alleine oder in Begleitung tun?",es:"La decisi\xf3n de comprar una casa es uno de los hitos financieros m\xe1s importantes de la vida. Pero, \xbfdeber\xeda hacerlo solo o acompa\xf1ado?",zh:"买房的决定是人生中最重要的财务里程碑之一。但是你应该独自一人还是结伴而行？"},post_credito_h2_1:{pt:"Comprar Sozinho",en:"Buying Alone",fr:"Acheter Seul",de:"Alleine kaufen",es:"Comprar Solo",zh:"独自购买"},post_credito_p1:{pt:"Comprar casa sozinho oferece total independ\xeancia nas decis\xf5es e na gest\xe3o do patrim\xf3nio.",en:"Buying a house alone offers total independence in decisions and asset management.",fr:"Acheter une maison seul offre une totale ind\xe9pendance dans les d\xe9cisions et la gestion du patrimoine.",de:"Ein Haus alleine zu kaufen, bietet v\xf6llige Unabh\xe4ngigkeit bei Entscheidungen und der Verm\xf6gensverwaltung.",es:"Comprar una casa solo ofrece total independencia en las decisiones y en la gesti\xf3n del patrimonio.",zh:"独自买房在决策和资产管理方面提供完全的独立性。"},post_credito_advantages:{pt:"Vantagens:",en:"Advantages:",fr:"Avantages :",de:"Vorteile:",es:"Ventajas:",zh:"优势："},post_credito_li1:{pt:"Decis\xe3o \xfanica sobre o im\xf3vel",en:"Sole decision over the property",fr:"D\xe9cision unique sur le bien",de:"Alleinige Entscheidung \xfcber die Immobilie",es:"Decisi\xf3n \xfanica sobre la propiedad",zh:"对房产拥有唯一决策权"},post_credito_li2:{pt:"Independ\xeancia financeira total",en:"Total financial independence",fr:"Ind\xe9pendance financi\xe8re totale",de:"Vollst\xe4ndige finanzielle Unabh\xe4ngigkeit",es:"Independencia financiera total",zh:"完全的财务独立"},post_credito_li3:{pt:"Processo simplificado em caso de venda",en:"Simplified process in case of sale",fr:"Processus simplifi\xe9 en cas de vente",de:"Vereinfachter Prozess im Falle eines Verkaufs",es:"Proceso simplificado en caso de venta",zh:"出售时流程简化"},post_credito_h2_2:{pt:"Comprar em Casal",en:"Buying as a Couple",fr:"Acheter en Couple",de:"Als Paar kaufen",es:"Comprar en Pareja",zh:"夫妻共同购买"},post_credito_p2:{pt:"Comprar a dois permite dividir os custos e, geralmente, aceder a montantes de financiamento superiores.",en:"Buying together allows you to split costs and generally access higher financing amounts.",fr:"Acheter \xe0 deux permet de partager les co\xfbts et, g\xe9n\xe9ralement, d'acc\xe9der \xe0 des montants de financement plus \xe9lev\xe9s.",de:"Der gemeinsame Kauf erm\xf6glicht es Ihnen, die Kosten zu teilen und in der Regel auf h\xf6here Finanzierungsbetr\xe4ge zuzugreifen.",es:"Comprar entre dos permite dividir los costes y, generalmente, acceder a montos de financiaci\xf3n superiores.",zh:"共同购买可以分摊成本，通常可以获得更高的融资额度。"},post_credito_advantages_2:{pt:"Vantagens:",en:"Advantages:",fr:"Avantages :",de:"Vorteile:",es:"Ventajas:",zh:"优势："},post_credito_li4:{pt:"Maior capacidade de financiamento",en:"Greater financing capacity",fr:"Plus grande capacit\xe9 de financement",de:"Gr\xf6\xdfere Finanzierungskapazit\xe4t",es:"Mayor capacidad de financiaci\xf3n",zh:"更强的融资能力"},post_credito_li5:{pt:"Partilha de despesas mensais",en:"Sharing of monthly expenses",fr:"Partage des d\xe9penses mensuelles",de:"Aufteilung der monatlichen Ausgaben",es:"Reparto de gastos mensuales",zh:"分摊每月开支"},post_credito_li6:{pt:"Redu\xe7\xe3o do risco financeiro individual",en:"Reduction of individual financial risk",fr:"R\xe9duction du risque financier individuel",de:"Reduzierung des individuellen finanziellen Risikos",es:"Reducci\xf3n del riesgo financiero individual",zh:"降低个人财务风险"},post_credito_h2_3:{pt:"Compara\xe7\xe3o de Financiamento",en:"Financing Comparison",fr:"Comparaison de Financement",de:"Finanzierungsvergleich",es:"Comparaci\xf3n de Financiaci\xf3n",zh:"融资比较"},post_credito_p3:{pt:"Veja como a taxa de esfor\xe7o e o rendimento dispon\xedvel mudam conforme a modalidade.",en:"See how the effort rate and available income change depending on the modality.",fr:"D\xe9couvrez comment le taux d'effort et le revenu disponible \xe9voluent selon la modalit\xe9.",de:"Sehen Sie, wie sich die Belastungsrate und das verf\xfcgbare Einkommen je nach Modalit\xe4t \xe4ndern.",es:"Vea c\xf3mo cambian la tasa de esfuerzo y los ingresos disponibles seg\xfan la modalidad.",zh:"了解还款能力和可用收入如何随模式而变化。"},post_credito_table_h1:{pt:"Indicador",en:"Indicator",fr:"Indicateur",de:"Indikator",es:"Indicador",zh:"指标"},post_credito_table_h2:{pt:"Individual",en:"Single",fr:"Individuel",de:"Einzeln",es:"Individual",zh:"个人"},post_credito_table_h3:{pt:"Casal",en:"Couple",fr:"Couple",de:"Paar",es:"Pareja",zh:"夫妻"},post_credito_table_r1_c1:{pt:"Taxa de Esfor\xe7o M\xe1xima",en:"Max Effort Rate",fr:"Taux d'effort max",de:"Maximale Belastungsquote",es:"Tasa de Esfuerzo M\xe1xima",zh:"最大还款比率"},post_credito_table_r1_c2:{pt:"35% a 40%",en:"35% to 40%",fr:"35% \xe0 40%",de:"35% bis 40%",es:"35% a 40%",zh:"35%至40%"},post_credito_table_r2_c1:{pt:"Avalia\xe7\xe3o de Risco",en:"Risk Assessment",fr:"\xc9valuation des risques",de:"Risikobewertung",es:"Evaluaci\xf3n de Riesgo",zh:"风险评估"},post_credito_table_r2_c2:{pt:"Moderada",en:"Moderate",fr:"Mod\xe9r\xe9e",de:"Moderat",es:"Moderada",zh:"中等"},post_credito_table_r2_c3:{pt:"Baixa",en:"Low",fr:"Faible",de:"Niedrig",es:"Baja",zh:"低"},post_credito_table_r3_c1:{pt:"Flexibilidade",en:"Flexibility",fr:"Flexibilit\xe9",de:"Flexibilit\xe4t",es:"Flexibilidad",zh:"灵活性"},post_credito_table_r3_c2:{pt:"Alta",en:"High",fr:"Haute",de:"Hoch",es:"Alta",zh:"高"},post_credito_table_r3_c3:{pt:"M\xe9dia",en:"Medium",fr:"Moyenne",de:"Mittel",es:"Media",zh:"中"},post_credito_table_r4_c1:{pt:"Capacidade de Poupan\xe7a",en:"Savings Capacity",fr:"Capacit\xe9 d'\xe9pargne",de:"Sparf\xe4higkeit",es:"Capacidad de Ahorro",zh:"储蓄能力"},post_credito_table_r4_c2:{pt:"Limitada",en:"Limited",fr:"Limit\xe9e",de:"Begrenzt",es:"Limitada",zh:"有限"},post_credito_table_r4_c3:{pt:"Elevada",en:"High",fr:"\xc9lev\xe9e",de:"Hoch",es:"Elevada",zh:"高"},post_credito_h2_4:{pt:'A "Rasteira" da Avalia\xe7\xe3o Banc\xe1ria',en:'The Bank Appraisal "Pitfall"',fr:"Le \xab Pi\xe8ge \xbb de l'\xe9valuation bancaire",de:"Die „Falle“ der Bankbewertung",es:'El "Escollo" de la Tasaci\xf3n Bancaria',zh:"银行评估的“陷阱”"},post_credito_p4:{pt:"Muitos neg\xf3cios falham porque a avalia\xe7\xe3o do banco fica abaixo do pre\xe7o de compra.",en:"Many deals fail because the bank's appraisal falls below the purchase price.",fr:"De nombreuses transactions \xe9chouent parce que l'\xe9valuation de la banque est inf\xe9rieure au prix d'achat.",de:"Viele Gesch\xe4fte scheitern, weil die Bankbewertung unter dem Kaufpreis liegt.",es:"Muchas operaciones fracasan porque la tasa\xe7\xe3o del banco queda por debajo del precio de compra.",zh:"许多交易失败是因为银行的评估低于购买价格。"},post_credito_alert_title:{pt:"Aten\xe7\xe3o ao LTV (Loan-to-Value)",en:"Watch out for LTV (Loan-to-Value)",fr:"Attention au LTV (Loan-to-Value)",de:"Achtung beim LTV (Beleihungsauslauf)",es:"Atenci\xf3n al LTV (Loan-to-Value)",zh:"注意 LTV（贷款价值比）"},post_credito_alert_p1:{pt:"O banco financia uma percentagem do menor valor entre:",en:"The bank finances a percentage of the lower value between:",fr:"La banque finance um pourcentage de la valeur la plus basse entre :",de:"Die Bank finanziert einen Prozentsatz des niedrigeren Wertes zwischen:",es:"El banco financia un porcentaje del menor valor entre:",zh:"银行按以下两者中的较低值提供一定比例的融资："},post_credito_alert_li1:{pt:"O pre\xe7o de compra do im\xf3vel",en:"The purchase price of the property",fr:"Le prix d'achat du bien",de:"Dem Kaufpreis der Immobilie",es:"El precio de compra del inmueble",zh:"房产的购买价格"},post_credito_alert_li2:{pt:"O valor da avalia\xe7\xe3o feita pelo banco",en:"The appraised value by the bank",fr:"La valeur d'\xe9valuation faite par la banque",de:"Dem von der Bank ermittelten Sch\xe4tzwert",es:"El valor de la tasaci\xf3n realizada por el banco",zh:"银行进行的评估价值"},post_credito_alert_li3:{pt:"Geralmente, o financiamento m\xe1ximo \xe9 de 90%",en:"Generally, the maximum financing is 90%",fr:"G\xe9n\xe9ralement, le financement maximum est de 90%",de:"In der Regel betr\xe4gt die maximale Finanzierung 90 %",es:"Generalmente, la financiaci\xf3n m\xe1xima es del 90%",zh:"通常，最高融资比例为90%"},post_credito_p5:{pt:"Se a avalia\xe7\xe3o for baixa, ter\xe1 de ter mais capital pr\xf3prio para a entrada.",en:"If the appraisal is low, you will need more equity for the down payment.",fr:"Si l'\xe9valuation est basse, vous devrez avoir plus de fonds propres pour l'acompte.",de:"Wenn die Bewertung niedrig ist, ben\xf6tigen Sie mehr Eigenkapital f\xfcr die Anzahlung.",es:"Si la tasaci\xf3n \xe9 baixa, ter\xe1 que tener m\xe1s capital propio para la entrada.",zh:"如果评估价值较低，则需要更多的自有资金作为首付。"},post_credito_h2_5:{pt:"Documentos Necess\xe1rios",en:"Required Documents",fr:"Documents N\xe9cessaires",de:"Erforderliche Dokumente",es:"Documentos Necesarios",zh:"所需文件"},post_credito_p6:{pt:"Prepare a sua documenta\xe7\xe3o com anteced\xeancia para evitar atrasos.",en:"Prepare your documentation in advance to avoid delays.",fr:"Pr\xe9parez votre documentation \xe0 l'avance pour \xe9viter les retards.",de:"Bereiten Sie Ihre Unterlagen im Voraus vor, um Verz\xf6gerungen zu vermeiden.",es:"Prepare su documentaci\xf3n con antelaci\xf3n para evitar retrasos.",zh:"提前准备好文件以避免延误。"},post_credito_docs_li1:{pt:"\xdaltimos 3 recibos de vencimento",en:"Last 3 payslips",fr:"3 derniers bulletins de salaire",de:"Letzte 3 Gehaltsabrechnungen",es:"\xdaltimos 3 recibos de n\xf3mina",zh:"最近3个月的工资单"},post_credito_docs_li2:{pt:"Declara\xe7\xe3o de IRS e Nota de Liquida\xe7\xe3o",en:"IRS declaration and Settlement Note",fr:"D\xe9claration d'imp\xf4ts (IRS)",de:"Steuererkl\xe4rung und Steuerbescheid",es:"Declaraci\xf3n de la renta (IRS)",zh:"税务申报表和清算通知"},post_credito_docs_li3:{pt:"Extratos banc\xe1rios (\xfaltimos 3 meses)",en:"Bank statements (last 3 months)",fr:"Relev\xe9s bancaires (3 derniers mois)",de:"Kontoausz\xfcge (letzte 3 Monate)",es:"Extractos bancarios (\xfaltimos 3 meses)",zh:"银行流水（最近3个月）"},post_credito_docs_li4:{pt:"Declara\xe7\xe3o da entidade patronal",en:"Employer statement",fr:"Attestation de l'employeur",de:"Arbeitgeberbescheinigung",es:"Certificado de la empresa",zh:"雇主证明"},post_credito_docs_li5:{pt:"Mapa de Responsabilidades do Banco de Portugal",en:"CRC (Credit Liabilities Map)",fr:"Relev\xe9 de la Banque Centrale",de:"Kreditauskunft (Schufa/Zentralbank)",es:"Mapa de Responsabilidades del Banco de Portugal",zh:"信用责任图（中央银行）"},post_credito_conclusion_title:{pt:"Conclus\xe3o",en:"Conclusion",fr:"Conclusion",de:"Fazit",es:"Conclusi\xf3n",zh:"结论"},post_credito_conclusion_p:{pt:"N\xe3o existe uma resposta \xfanica. A melhor op\xe7\xe3o depende da sua estabilidade financeira e dos seus objetivos de vida.",en:"There is no single answer. The best option depends on your financial stability and life goals.",fr:"Il n'y a pas de r\xe9ponse unique. La meilleure option d\xe9pend de votre stabilit\xe9 financi\xe8re et de vos objectifs de vie.",de:"Es gibt keine allgemeing\xfcltige Antwort. Die beste Option h\xe4ngt von Ihrer finanziellen Stabilit\xe4t und Ihren Lebenszielen ab.",es:"No existe una respuesta \xfanica. La melhor opci\xf3n depende de su estabilidad financiera y de sus objetivos de vida.",zh:"没有唯一的答案。最佳选择取决于您的财务稳定性和生活目标。"},post_credito_cta_title:{pt:"Precisa de ajuda com o seu cr\xe9dito?",en:"Need help with your mortgage?",fr:"Besoin d'aide pour votre cr\xe9dit ?",de:"Ben\xf6tigen Sie Hilfe bei Ihrem Kredit?",es:"\xbfNecesita ayuda con su hipoteca?",zh:"需要贷款方面的帮助吗？"},post_credito_cta_p1:{pt:"Temos parcerias com intermedi\xe1rios de cr\xe9dito que podem negociar as melhores condi\xe7\xf5es para si.",en:"We have partnerships with credit intermediaries who can negotiate the best conditions for you.",fr:"Nous avons des partenariats avec des interm\xe9diaires de cr\xe9dit qui peuvent n\xe9gocier les meilleures conditions pour vous.",de:"Wir haben Partnerschaften mit Kreditvermittlern, die die besten Konditionen f\xfcr Sie aushandeln k\xf6nnen.",es:"Tenemos convenios con intermediarios de cr\xe9dito que pueden negociar las mejores condiciones para usted.",zh:"我们与信用中介机构建立了合作伙伴关系，可以为您协商最优惠的条件。"},post_credito_cta_p2:{pt:"Este servi\xe7o \xe9 gratuito e pode poupar-lhe muito dinheiro.",en:"This service is free and can save you a lot of money.",fr:"Ce service est gratuit et peut vous faire \xe9conomiser beaucoup d'argent.",de:"Dieser Service ist kostenlos und kann Ihnen viel Geld sparen.",es:"Este servicio es gratuito y puede ahorrarle mucho dinero.",zh:"此项服务是免费的，可以为您节省大量资金。"},post_credito_cta_button:{pt:"Falar com um Consultor",en:"Talk to a Consultant",fr:"Parler \xe0 um Consultant",de:"Mit einem Berater sprechen",es:"Hablar con un Consultor",zh:"咨询顾问"},post_erros_main_title:{pt:"5 Erros que Impedem a Venda do seu Im\xf3vel em Lisboa",en:"5 Mistakes Preventing the Sale of Your Property in Lisbon",fr:"5 Erreurs qui Emp\xeachent la Vente de Votre Bien \xe0 Lisbonne",de:"5 Fehler, die den Verkauf Ihrer Immobilie in Lissabon verhindern",es:"5 Errores que Impiden la Venta de su Propiedad en Lisboa",zh:"导致您在里斯本的房产无法售出的5个错误"},post_erros_subtitle:{pt:"Descubra porque \xe9 que alguns an\xfancios s\xe3o ignorados e como valorizar o seu im\xf3vel.",en:"Find out why some ads are ignored and how to increase your property's value.",fr:"D\xe9couvrez pourquoi certaines annonces sont ignor\xe9es et comment valoriser votre bien.",de:"Finden Sie heraus, warum einige Anzeigen ignoriert werden und wie Sie Ihre Immobilie aufwerten k\xf6nnen.",es:"Descubra por qu\xe9 se ignoran algunos anuncios y c\xf3mo valorizar su propiedad.",zh:"了解为什么有些房源会被忽视，以及如何让您的房产增值。"},post_erros_1_title:{pt:"Fotografias de Baixa Qualidade",en:"Poor Quality Photos",fr:"Photos de mauvaise qualit\xe9",de:"Minderwertige Fotos",es:"Fotograf\xedas de Baja Calidad",zh:"低质量的照片"},post_erros_1_item1:{pt:"A primeira impress\xe3o \xe9 a que conta. Fotos escuras ou desfocadas afastam compradores.",en:"First impressions matter. Dark or blurry photos drive away buyers.",fr:"La premi\xe8re impression est celle qui compte. Des photos sombres ou floues \xe9loignent les acheteurs.",de:"Der erste Eindruck z\xe4hlt. Dunkle oder unscharfe Fotos schrecken K\xe4ufer ab.",es:"La primera impresi\xf3n es la que cuenta. Fotos oscuras o desenfocadas alejan a los compradores.",zh:"第一印象至关重要。昏暗或模糊的照片会让买家望而却步。"},post_erros_1_item2:{pt:"Impacto: Menos visualiza\xe7\xf5es e menor percep\xe7\xe3o de valor.",en:"Impact: Fewer views and lower perceived value.",fr:"Impact : Moins de vues et une perception de valeur plus faible.",de:"Auswirkung: Weniger Aufrufe und geringere Wertwahrnehmung.",es:"Impacto: Menos visualizaciones y menor percepci\xf3n de valor.",zh:"影响：点击量减少，价值感降低。"},post_erros_1_item3:{pt:"Solu\xe7\xe3o: Reportagem fotogr\xe1fica profissional.",en:"Solution: Professional photo shoot.",fr:"Solution : Reportage photo professionnel.",de:"L\xf6sung: Professionelle Fotografie.",es:"Soluci\xf3n: Reportaje fotogr\xe1fico profesional.",zh:"解决方案：专业的摄影服务。"},post_erros_2_title:{pt:"Pre\xe7o Fora de Mercado",en:"Pricing Out of Market",fr:"Prix hors march\xe9",de:"Preis n\xe3o marktgerecht",es:"Precio Fuera de Mercado",zh:"定价脱离市场"},post_erros_2_item1:{pt:"Um pre\xe7o demasiado elevado faz com que o im\xf3vel fique estagnado no mercado.",en:"An excessively high price causes the property to stagnate on the market.",fr:"Un prix trop \xe9lev\xe9 fait stagner le bien sur le march\xe9.",de:"Ein zu hoher Preis f\xfchrt dazu, dass die Immobilie am Markt stagniert.",es:"Un precio demasiado elevado hace que el inmueble quede estancado en el mercado.",zh:"价格过高会导致房产在市场上滞销。"},post_erros_2_item2:{pt:"Erro: Basear o pre\xe7o em valor sentimental ou no que o vizinho disse.",en:"Error: Basing price on sentimental value or neighbor's hearsay.",fr:"Erreur : Baser le prix sur la valeur sentimentale ou les dires du voisin.",de:"Fehler: Den Preis auf sentimentalem Wert oder H\xf6rensagen basieren.",es:"Error: Basar el precio en el valor sentimental o en lo que dijo el vecino.",zh:"错误：基于情感价值或邻居的说法来定价。"},post_erros_2_item3:{pt:"Solu\xe7\xe3o: An\xe1lise de mercado comparativa (CMA).",en:"Solution: Comparative Market Analysis (CMA).",fr:"Solution : Analyse comparative de march\xe9 (ACM).",de:"L\xf6sung: Vergleichende Marktanalyse (VMA).",es:"Soluci\xf3n: An\xe1lisis de mercado comparativo (CMA).",zh:"解决方案：比较市场分析 (CMA)。"},post_erros_3_title:{pt:"Falta de Exposi\xe7\xe3o Digital",en:"Lack of Digital Exposure",fr:"Manque d'exposition num\xe9rique",de:"Mangelnde digitale Sichtbarkeit",es:"Falta de Exposici\xf3n Digital",zh:"缺乏数字曝光"},post_erros_3_item1:{pt:"N\xe3o basta colocar uma placa. O comprador est\xe1 online.",en:"Putting up a sign isn't enough. The buyer is online.",fr:"Mettre un panneau ne suffit pas. L'acheteur est en ligne.",de:"Ein Schild aufzustellen reicht nicht aus. Der K\xe4ufer ist online.",es:"No basta con poner un cartel. El comprador est\xe1 online.",zh:"仅仅挂个牌子是不够的。买家都在网上。"},post_erros_3_item2:{pt:"Erro: Limitar a promo\xe7\xe3o a apenas um portal ou redes sociais pessoais.",en:"Error: Limiting promotion to just one portal or personal social media.",fr:"Erreur : Limiter la promotion \xe0 un seul portail ou aux r\xe9seaux sociaux personnels.",de:"Fehler: Die Vermarktung auf nur ein Portal oder pers\xf6nliche soziale Medien beschr\xe4nken.",es:"Error: Limitar la promoci\xf3n a un solo portal o redes sociales personales.",zh:"错误：仅限一个门户网站或个人社交媒体进行推广。"},post_erros_3_item3:{pt:"Solu\xe7\xe3o: Plano de marketing digital multicanal.",en:"Solution: Multi-channel digital marketing plan.",fr:"Solution : Plan de marketing num\xe9rique multicanal.",de:"L\xf6sung: Multi-Channel-Digital-Marketingplan.",es:"Soluci\xf3n: Plan de marketing digital multicanal.",zh:"解决方案：多渠道数字营销计划。"},post_erros_4_title:{pt:"Im\xf3vel N\xe3o Preparado (Home Staging)",en:"Property Not Prepared (Home Staging)",fr:"Bien non pr\xe9par\xe9 (Home Staging)",de:"Immobilie n\xe3o vorbereitet (Home Staging)",es:"Inmueble No Preparado (Home Staging)",zh:"房产未做准备（家居布置）"},post_erros_4_item1:{pt:"A desorganiza\xe7\xe3o ou excesso de personaliza\xe7\xe3o dificulta a vis\xe3o do comprador.",en:"Disorganization or excessive personalization makes it hard for the buyer to envision themselves there.",fr:"Le d\xe9sordre ou l'exc\xe8s de personnalisation emp\xeache l'acheteur de se projeter.",de:"Unordnung oder zu viel Personalisierung erschweren es dem K\xe4ufer, sich dort wohlzuf\xfchlen.",es:"El desorden o el exceso de personalizaci\xf3n dificulta la visi\xf3n del comprador.",zh:"杂乱无章或过度个性化会让买家难以想象自己住在这里。"},post_erros_4_item2:{pt:"Erro: Mostrar a casa com objetos pessoais em excesso ou sujidade.",en:"Error: Showing the house with excessive personal items or dirt.",fr:"Erreur : Montrer la maison avec trop d'objets personnels ou de la salet\xe9.",de:"Fehler: Das Haus mit zu vielen pers\xf6nlichen Gegenst\xe4nden oder Schmutz zeigen.",es:"Error: Mostrar la casa con objetos personales en exceso o suciedad.",zh:"错误：展示房屋时留有过多个人物品或不整洁。"},post_erros_4_item3:{pt:"Solu\xe7\xe3o: Despersonaliza\xe7\xe3o e pequenos reparos.",en:"Solution: Depersonalization and minor repairs.",fr:"Solution : D\xe9personnalisation et petites r\xe9parations.",de:"L\xf6sung: Entpersonalisierung und kleine Reparaturen.",es:"Soluci\xf3n: Despersonalizaci\xf3n y peque\xf1as reparaciones.",zh:"解决方案：去个性化和微调修缮。"},post_erros_5_title:{pt:"M\xe1 Gest\xe3o de Visitas",en:"Poor Visit Management",fr:"Mauvaise gestion des visites",de:"Schlechtes Besichtigungsmanagement",es:"Mala Gesti\xf3n de Visitas",zh:"带看管理不善"},post_erros_5_item1:{pt:"Falta de acompanhamento ou dificuldade em agendar visitas.",en:"Lack of follow-up or difficulty in scheduling visits.",fr:"Manque de suivi ou difficult\xe9 \xe0 planifier les visites.",de:"Mangelnde Nachbereitung oder Schwierigkeiten bei der Terminvereinbarung.",es:"Falta de seguimiento o dificultad para concertar visitas.",zh:"缺乏跟进或难以安排带看时间。"},post_erros_5_item2:{pt:"Erro: N\xe3o qualificar os interessados antes da visita.",en:"Error: Not qualifying leads before the visit.",fr:"Erreur : Ne pas qualifier les prospects avant la visite.",de:"Fehler: Interessenten vor der Besichtigung n\xe3o qualifizieren.",es:"Error: No cualificar a los interesados antes de la visita.",zh:"错误：在带看之前没有对潜在客户进行资质审核。"},post_erros_5_item3:{pt:"Solu\xe7\xe3o: Gest\xe3o profissional de agenda e feedback constante.",en:"Solution: Professional schedule management and constant feedback.",fr:"Solution : Gestion professionnelle du planning et feedback constant.",de:"L\xf6sung: Professionelles Terminmanagement und st\xe4ndiges Feedback.",es:"Soluci\xf3n: Gest\xe3o profissional de agenda e feedback constante.",zh:"解决方案：专业的日程管理和持续的反馈。"},post_erros_conclusion_title:{pt:"Conclus\xe3o",en:"Conclusion",fr:"Conclusion",de:"Fazit",es:"Conclusi\xf3n",zh:"结论"},post_erros_conclusion_p:{pt:"Vender um im\xf3vel exige estrat\xe9gia e profissionalismo. Evitar estes erros \xe9 o primeiro passo para um neg\xf3cio de sucesso.",en:"Selling a property requires strategy and professionalism. Avoiding these mistakes is the first step toward a successful deal.",fr:"Vendre un bien exige strat\xe9gie et professionnalisme. \xc9viter ces erreurs est la premi\xe8re \xe9tape vers une transaction r\xe9ussie.",de:"Der Verkauf einer Immobilie erfordert Strategie und Professionalit\xe4t. Diese Fehler zu vermeiden, ist der erste Schritt zu einem erfolgreichen Gesch\xe4ft.",es:"Vender un inmueble exige estrategia y profesionalidad. Evitar estos errores es el primer paso para una operaci\xf3n de \xe9xito.",zh:"卖房需要策略和专业精神。避免这些错误是迈向成功交易的第一步。"},post_erros_cta_title:{pt:"Quer vender o seu im\xf3vel pelo melhor pre\xe7o?",en:"Want to sell your property for the best price?",fr:"Vous voulez vendre votre bien au meilleur prix ?",de:"M\xf6chten Sie Ihre Immobilie zum besten Preis verkaufen?",es:"\xbfQuiere vender su propiedad al melhor precio?",zh:"想以最好的价格出售您的房产吗？"},post_erros_cta_p:{pt:"Fale comigo. Desenvolvo um plano de marketing personalizado para o seu im\xf3vel.",en:"Talk to me. I will develop a personalized marketing plan for your property.",fr:"Contactez-moi. Je d\xe9veloppe un plan de marketing personnalis\xe9 pour votre bien.",de:"Sprechen Sie mit mir. Ich entwickle einen personalisierten Marketingplan f\xfcr Ihre Immobilie.",es:"Hable conmigo. Desarrollar\xe9 un plan de marketing personalizado para su inmueble.",zh:"联系我。我将为您的房产制定个性化的营销计划。"},post_erros_cta_button:{pt:"Come\xe7ar Agora",en:"Start Now",fr:"Commencer Maintenant",de:"Jetzt starten",es:"Empezar Ahora",zh:"立即开始"},trespasse_post_main_title:{pt:"Trespasse de Neg\xf3cio em Portugal: O que Precisa de Saber para N\xe3o Cometer Erros!",en:"Business Transfer in Portugal: What You Need to Know to Avoid Mistakes!",fr:"Cession de fonds de commerce au Portugal : ce qu'il faut savoir pour ne pas commettre d'erreurs !",de:"Gesch\xe4fts\xfcbertragung in Portugal: Was Sie wissen m\xfcssen, um Fehler zu vermeiden!",es:"Traspaso de negocio en Portugal: \xa1Lo que necesita saber para no cometer errores!",zh:"葡萄牙商业转让：避免错误的必知事项！"},trespasse_post_subtitle:{pt:"Decidir passar o testemunho de um neg\xf3cio \xe9 uma decis\xe3o estrat\xe9gica que exige rigor e uma prepara\xe7\xe3o t\xe9cnica minuciosa. No mercado atual, um trespasse bem executado pode representar o capital necess\xe1rio para o seu pr\xf3ximo grande projeto. No entanto, muitos propriet\xe1rios perdem valor ou enfrentam lit\xedgios judiciais por desconhecerem as regras fundamentais deste processo.",en:"Deciding to pass on a business is a strategic decision that requires rigor and meticulous technical preparation. In today's market, a well-executed transfer can provide the necessary capital for your next big project. However, many owners lose value or face legal disputes because they are unaware of the fundamental rules of this process.",fr:"D\xe9cider de transmettre une entreprise est une d\xe9cision strat\xe9gique qui exige de la rigueur et une pr\xe9paration technique minutieuse. Sur le march\xe9 actuel, une cession bien ex\xe9cut\xe9e peut repr\xe9senter le capital n\xe9cessaire \xe0 votre prochain grand projet. Cependant, de nombreux propri\xe9taires perdent de la valeur ou font face \xe0 des litiges judiciaires parce qu'ils m\xe9connaissent les r\xe8gles fondamentales de ce processus.",de:"Die Entscheidung, ein Unternehmen weiterzugeben, ist eine strategische Entscheidung, die Genauigkeit und sorgf\xe4ltige technische Vorbereitung erfordert. Auf dem heutigen Markt kann eine gut durchgef\xfchrte \xdcbertragung das notwendige Kapital f\xfcr Ihr n\xe4chstes gro\xdfes Projekt bedeuten. Viele Eigent\xfcmer verlieren jedoch an Wert oder sehen sich mit Rechtsstreitigkeiten konfrontiert, weil sie die grundlegenden Regeln dieses Prozesses nicht kennen.",es:"Decidir traspasar um negocio es una decisi\xf3n estrat\xe9gica que requiere rigor y una preparaci\xf3n t\xe9cnica minuciosa. En el mercado actual, un traspaso bien executado puede representar el capital necesario para su pr\xf3ximo gran proyecto. Sin embargo, muchos propietarios pierden valor o se enfrentan a litigios judiciales por desconhecer las reglas fundamentales de este proceso.",zh:"决定转让一项业务是一项需要严谨和细致技术准备的战略决策。在当今市场，一次成功的转让可以为您下一个宏大项目提供必要的资本。然而，许多业主因不了解此过程的基本规则而遭受价值损失或面临法律纠纷。"},trespasse_post_intro:{pt:"Se pretende vender o seu estabelecimento em funcionamento, estes s\xe3o os pontos cr\xedticos que n\xe3o pode ignorar em 2026.",en:"If you intend to sell your operating establishment, these are the critical points you cannot ignore in 2026.",fr:"Si vous avez l'intention de vendre votre \xe9tablissement en exploitation, voici les points critiques que vous ne pouvez pas ignorer en 2026.",de:"Wenn Sie beabsichtigen, Ihr in Betrieb befindliches Unternehmen zu verkaufen, sind dies die entscheidenden Punkte, die Sie im Jahr 2026 nicht ignorieren d\xfcrfen.",es:"Si tiene la intenci\xf3n de vender su establecimiento en funcionamiento, estos son los puntos cr\xedticos que n\xe3o pode ignorar en 2026.",zh:"如果您打算出售您正在运营的店铺，这些是您在2026年不能忽视的关键点。"},trespasse_post_point1_title:{pt:"1. O Trespasse n\xe3o \xe9 apenas a venda de ativos",en:"1. The Transfer is not just the sale of assets",fr:"1. La cession n'est pas seulement la vente d'actifs",de:"1. Die \xdcbertragung ist nicht nur der Verkauf von Verm\xf6genswerten",es:"1. El traspaso n\xe3o es solo la venta de activos",zh:"1. 转让不仅仅是资产的出售"},trespasse_p1_main:{pt:"\xc9 frequente confundir-se o trespasse com a mera venda de equipamentos ou mobili\xe1rio. O trespasse configura a transmiss\xe3o da unidade econ\xf3mica completa. Este processo abrange o nome comercial, a carteira de clientes, as exist\xeancias e, acima de tudo, o direito de utiliza\xe7\xe3o do espa\xe7o atrav\xe9s do contrato de arrendamento.",en:"It is common to confuse the transfer with the mere sale of equipment or furniture. The transfer involves the transmission of the entire economic unit. This process includes the trade name, customer portfolio, inventory, and, above all, the right to use the space through the lease agreement.",fr:"Il est courant de confondre la cession avec la simple vente d'\xe9quipements ou de mobilier. La cession implique la transmission de l'unit\xe9 \xe9conomique compl\xe8te. Ce processus inclut le nom commercial, le portefeuille de clients, les stocks et, surtout, le droit d'utiliser l'espace via le contrat de bail.",de:"Es ist \xfcblich, die \xdcbertragung mit dem reinen Verkauf von Ger\xe4ten oder M\xf6beln zu verwechseln. Die \xdcbertragung umfasst die \xdcbermittlung der gesamten wirtschaftlichen Einheit. Dieses Prozess beinhaltet den Handelsnamen, das Kundenportfolio, den Lagerbestand und vor allem das Recht, den Raum durch den Mietvertrag zu nutzen.",es:"Es com\xfan confundir el traspaso con la mera venta de equipos o mobili\xe1rio. El traspaso implica la transmisi\xf3n de la unidad econ\xf3mica completa. Este proceso incluye el nombre comercial, la cartera de clientes, el invent\xe1rio e, sobre todo, el derecho a utilizar el espacio a trav\xe9s del contrato de arrendamiento.",zh:"人们常常将商业转让与仅仅出售设备或家具相混淆。转让涉及整个经济单位的转移。这一过程包括商号、客户组合、库存，以及最重要的，通过租赁协议使用该场所的权利。"},trespasse_p1_note_strong:{pt:"Nota fundamental:",en:"Fundamental note:",fr:"Note fondamentale :",de:"Grundlegender Hinweis:",es:"Nota fundamental:",zh:"基本说明："},trespasse_p1_note_text:{pt:" Para que seja juridicamente v\xe1lido como trespasse, o estabelecimento deve ser transmitido de forma a que se permita a continuidade imediata da atividade econ\xf3mica.",en:" For it to be legally valid as a transfer, the establishment must be transmitted in a way that allows for the immediate continuation of the economic activity.",fr:" Pour qu'elle soit juridiquement valable en tant que cession, l'\xe9tablissement doit \xeatre transmis de mani\xe8re \xe0 permettre la poursuite imm\xe9diate de l'activit\xe9 \xe9conomique.",de:" Damit es rechtlich als \xdcbertragung g\xfcltig ist, muss das Unternehmen so \xfcbertragen werden, dass eine sofortige Fortsetzung der wirtschaftlichen T\xe4tigkeit m\xf6glich ist.",es:" Para que sea legalmente v\xe1lido como traspaso, el establecimiento debe transmitirse de manera que permita la continuaci\xf3n inmediata de la actividad econ\xf3mica.",zh:" 为使其在法律上被视为有效转让，该店铺的转让方式必须能够确保经济活动的立即延续。"},trespasse_post_point2_title:{pt:"2. A Relev\xe2ncia do Direito de Prefer\xeancia",en:"2. The Relevance of the Right of First Refusal",fr:"2. La Pertinence du Droit de Pr\xe9emption",de:"2. Die Relevanz des Vorkaufsrechts",es:"2. La relevancia del derecho de tanteo",zh:"2. 优先购买权的重要性"},trespasse_p2_main1:{pt:"O senhorio desempenha um papel determinante neste processo. Embora, regra geral, n\xe3o necessite da sua autoriza\xe7\xe3o para efetuar o trespasse — desde que se mantenha o mesmo ramo de atividade —, \xe9 imperativo que se respeite o seu Direito de Prefer\xeancia.",en:"The landlord plays a decisive role in this process. Although, as a general rule, their authorization is not required to carry out the transfer—as long as the same line of business is maintained—it is imperative to respect their Right of First Refusal.",fr:"Le propri\xe9taire joue un r\xf4le d\xe9cisif dans ce processus. Bien qu'en r\xe8gle g\xe9n\xe9rale, son autorisation ne soit pas requise pour effectuer la cession — tant que le mesmo secteur d'activit\xe9 est maintenu — il est imp\xe9ratif de respecter son droit de pr\xe9emption.",de:"Der Vermieter spielt in diesem Prozess eine entscheidende Rolle. Obwohl seine Genehmigung zur Durchf\xfchrung der \xdcbertragung in der Regel nicht erforderlich ist – solange die gleiche Gesch\xe4ftst\xe4tigkeit beibehalten wird – ist es unerl\xe4sslich, sein Vorkaufsrecht zu respektieren.",es:"El arrendador juega um papel decisivo en este proceso. Aunque, por regla general, no se requiere su autorizaci\xf3n para realizar el traspaso —siempre que se mantenga el mismo ramo de actividad—, es imperativo respetar su derecho de tanteo.",zh:"房东在这一过程中扮演着决定性角色。虽然通常情况下，只要业务范围保持不变，进行转让无需其授权，但尊重其优先购买权是强制性的。"},trespasse_p2_main2:{pt:"Devemos comunicar as condi\xe7\xf5es e o valor da venda atrav\xe9s de carta registada com aviso de rece\xe7\xe3o.",en:"We must communicate the conditions and value of the sale by registered letter with acknowledgment of receipt.",fr:"Nous devons communiquer les conditions et la valeur de la vente par lettre recommand\xe9e avec accus\xe9 de r\xe9ception.",de:"Wir m\xfcssen die Bedingungen und den Wert des Verkaufs per Einschreiben mit R\xfcckschein mitteilen.",es:"Debemos comunicar las condiciones y el valor de la venta por carta certificada con acuse de recibo.",zh:"我们必须通过带回执的挂号信函，通知（房东）出售的条款和价格。"},trespasse_p2_main3:{pt:"O senhorio disp\xf5e de um prazo legal para decidir se deseja exercer o direito de adquirir o neg\xf3cio pelo valor acordado com o terceiro interessado.",en:"The landlord has a legal period to decide whether to exercise the right to acquire the business for the value agreed with the interested third party.",fr:"Le propri\xe9taire dispose d'un d\xe9lai l\xe9gal pour d\xe9cider s'il souhaite exercer le droit d'acqu\xe9rir l'entreprise \xe0 la valeur convenue avec le tiers int\xe9ress\xe9.",de:"Der Vermieter hat eine gesetzliche Frist, um zu entscheiden, ob er das Recht aus\xfcben m\xf6chte, das Gesch\xe4ft zu dem mit dem interessierten Dritten vereinbarten Wert zu erwerben.",es:"El arrendador tiene um prazo legal para decidir si desea ejercer el derecho de adquirir el negocio por el valor acordado con el tercero interesado.",zh:"房东在法律规定的一段时间内，有权决定是否行使以与第三方协商好的价格收购该业务的权利。"},trespasse_p2_warning_strong:{pt:"Aviso:",en:"Warning:",fr:"Avertissement :",de:"Warnung:",es:"Aviso:",zh:"警告："},trespasse_p2_warning_text:{pt:" A omiss\xe3o deste passo pode resultar na anula\xe7\xe3o do neg\xf3cio em sede judicial.",en:" Failure to take this step can result in the annulment of the deal in court.",fr:" L'omission de cette \xe9tape peut entra\xeener l'annulation de la transaction en justice.",de:" Die Unterlassung dieses Schrittes kann zur gerichtlichen Annullierung des Gesch\xe4fts f\xfchren.",es:" La omisi\xf3n de este paso puede dar lugar a la anulaci\xf3n del negocio en los tribunales.",zh:" 忽略此步骤可能导致该交易在法庭上被宣告无效。"},trespasse_post_point3_title:{pt:"3. Documenta\xe7\xe3o: A sua Salvaguarda Jur\xeddica",en:"3. Documentation: Your Legal Safeguard",fr:"3. Documentation : Votre protection juridique",de:"3. Dokumentation: Ihre rechtliche Absicherung",es:"3. Documentaci\xf3n: Su salvaguarda jur\xeddica",zh:"3. 文件：您的法律保障"},trespasse_p3_main:{pt:"Para que um trespasse seja seguro, a documenta\xe7\xe3o deve estar irrepreens\xedvel. Quaisquer falhas neste campo desvalorizam o neg\xf3cio de imediato e afastam potenciais investidores:",en:"For a transfer to be secure, the documentation must be impeccable. Any flaws in this area immediately devalue the business and deter potential investors:",fr:"Pour qu'une cession soit s\xe9curis\xe9e, la documentation doit \xeatre irr\xe9prochable. Toute lacune dans ce domaine d\xe9valorise imm\xe9diatement l'entreprise et dissuade les investisseurs potentiels :",de:"Damit eine \xdcbertragung sicher ist, muss die Dokumentation einwandfrei sein. Jegliche M\xe4ngel in diesem Bereich entwerten das Gesch\xe4ft sofort und schrecken potenzielle Investoren ab:",es:"Para que um traspaso sea seguro, la documentaci\xf3n debe ser impecable. Cualquier fallo en este campo deval\xfaa inmediatamente el negocio y disuade a los inversores potenciales:",zh:"为确保转让安全，文件必须完美无缺。此领域的任何瑕疵都会立即降低业务价值并吓退潜在投资者："},trespasse_p3_list_0:{pt:"Contrato de Trespasse: Deve ser redigido com precis\xe3o, discriminando minuciosamente os ativos e os passivos transmitidos.",en:"Transfer Agreement: It must be drafted with precision, meticulously itemizing the assets and liabilities being transferred.",fr:"Contrat de cession : Il doit \xeatre r\xe9dig\xe9 avec pr\xe9cision, en d\xe9taillant m\xe9ticuleusement les actifs et les passifs transf\xe9r\xe9s.",de:"\xdcbertragungsvertrag: Er muss pr\xe4zise formuliert sein und die \xfcbertragenen Verm\xf6genswerte und Verbindlichkeiten detailliert auflisten.",es:"Contrato de traspaso: Debe redactarse con precisi\xf3n, detallando meticulosamente los activos y pasivos que se transfieren.",zh:"转让协议：必须精确起草，详细列明所转让的资产和负债。"},trespasse_p3_list_1:{pt:"Certid\xf5es de N\xe3o D\xedvida: S\xe3o fundamentais para garantir ao comprador a aus\xeancia de encargos perante a Autoridade Tribut\xe1ria e a Seguran\xe7a Social.",en:"Certificates of No Debt: They are essential to assure the buyer of the absence of debts to the Tax Authority and Social Security.",fr:"Certificats de non-endettement : Ils sont essentiels pour garantir \xe0 l'acheteur l'absence de dettes aupr\xe8s de l'administration fiscale et de la s\xe9curit\xe9 sociale.",de:"Unbedenklichkeitsbescheinigungen: Sie sind unerl\xe4sslich, um dem K\xe4ufer die Schuldenfreiheit gegen\xfcber der Steuerbeh\xf6rde und der Sozialversicherung zu gew\xe4hrleisten.",es:"Certificados de no adeudo: Son fundamentales para garantizar al comprador la ausencia de deudas con la Hacienda P\xfablica y la Seguridad Social.",zh:"无债务证明：这些证明至关重要，可以向买方保证不存在欠税务局和社会保障局的债务。"},trespasse_p3_list_2:{pt:"Alvar\xe1s e Licenciamentos: Verificamos sempre se as licen\xe7as de utiliza\xe7\xe3o est\xe3o em conformidade com as normas municipais e setoriais em vigor.",en:"Permits and Licenses: We always check if the usage licenses comply with current municipal and sectoral regulations.",fr:"Permis et licences : Nous v\xe9rifions toujours si les licences d'utilisation sont conformes aux r\xe9glementations municipales et sectorielles en vigueur.",de:"Genehmigungen und Lizenzen: Wir pr\xfcfen immer, ob die Nutzungsgenehmigungen den geltenden kommunalen und branchenspezifischen Vorschriften entsprechen.",es:"Permisos y licencias: Siempre comprobamos si las licencias de uso cumplen con la normativa municipal y sectorial vigente.",zh:"许可和执照：我们总是核查使用许可证是否符合现行的市政和行业法规。"},trespasse_post_point4_title:{pt:"4. Como determinamos o valor real (Valuation)",en:"4. How we determine the real value (Valuation)",fr:"4. Comment nous d\xe9terminons la valeur r\xe9elle (\xc9valuation)",de:"4. Wie wir den tats\xe4chlichen Wert ermitteln (Bewertung)",es:"4. C\xf3mo determinamos el valor real (Valoraci\xf3n)",zh:"4. 我们如何确定真实价值（估值）"},trespasse_p4_main:{pt:"N\xe3o estabelecemos pre\xe7os com base em estimativas vagas ou valor sentimental. No mercado atual, analisamos indicadores objetivos e financeiros:",en:"We do not set prices based on vague estimates or sentimental value. In the current market, we analyze objective and financial indicators:",fr:"Nous ne fixons pas les prix sur la base d'estimations vagues ou de valeur sentimentale. Sur le march\xe9 actuel, nous analysons des indicateurs objectifs et financiers :",de:"Wir legen keine Preise auf der Grundlage vager Sch\xe4tzungen oder sentimentalen Werts fest. Auf dem aktuellen Markt analysieren wir objektive und finanzielle Indikatoren:",es:"No fijamos los precios bas\xe1ndonos en estimaciones vagas o en el valor sentimental. En el mercado actual, analisamos indicadores objetivos e financieros:",zh:"我们不根据模糊的估计或情感价值来定价。在当前市场中，我们分析客观和财务指标："},trespasse_p4_list_0:{pt:"Rentabilidade (EBITDA): O lucro operacional apurado nos \xfaltimos exerc\xedcios contabil\xedsticos.",en:"Profitability (EBITDA): The operating profit determined in the last fiscal years.",fr:"Rentabilit\xe9 (EBITDA) : Le b\xe9n\xe9fice d'exploitation d\xe9termin\xe9 au cours des derniers exercices fiscaux.",de:"Rentabilit\xe4t (EBITDA): Der in den letzten Gesch\xe4ftsjahren ermittelte Betriebsgewinn.",es:"Rentabilidad (EBITDA): El beneficio de explotaci\xf3n determinado en los \xfaltimos ejercicios fiscales.",zh:"盈利能力（EBITDA）：过去几个财年确定的营业利润。"},trespasse_p4_list_1:{pt:"Localiza\xe7\xe3o e Potencial: A atratividade da zona, o fluxo de clientes consolidado e as perspetivas de crescimento.",en:"Location and Potential: The attractiveness of the area, the consolidated customer flow, and growth prospects.",fr:"Emplacement et potentiel : L'attractivit\xe9 de la zone, le flux de clients consolid\xe9 et les perspectives de croissance.",de:"Standort und Potenzial: Die Attraktivit\xe4t des Gebiets, der konsolidierte Kundenstrom und die Wachstumsaussichten.",es:"Ubicaci\xf3n y potencial: El atractivo de la zona, el flujo de clientes consolidado y las perspectivas de crecimiento.",zh:"地理位置与潜力：该地区的吸引力、稳固的客流量以及增长前景。"},trespasse_p4_list_2:{pt:"Contrato de Arrendamento: Um contrato est\xe1vel com uma renda competitiva constitui um ativo de elevado valor num trespasse de neg\xf3cio.",en:"Lease Agreement: A stable contract with a competitive rent is a high-value asset in a business transfer.",fr:"Contrat de bail : Un contrat stable avec un loyer comp\xe9titif est un atout de grande valeur dans une cession d'entreprise.",de:"Mietvertrag: Ein stabiler Vertrag mit einer wettbewerbsf\xe4higen Miete ist ein hochwertiger Verm\xf6genswert bei einer Gesch\xe4fts\xfcbertragung.",es:"Contrato de arrendamiento: Un contrato estable con un alquiler competitivo es un activo de gran valor en un traspaso de negocio.",zh:"租赁协议：一份租金有竞争力的稳定合同在商业转让中是一项高价值资产。"},trespasse_p4_advice_strong:{pt:"O meu conselho:",en:"My advice:",fr:"Mon conseil :",de:"Mein Rat:",es:"Mi consejo:",zh:"我的建议："},trespasse_p4_advice_text:{pt:" Um neg\xf3cio que negligencie a sua gest\xe3o ou imagem p\xfablica nos meses que antecedem a venda perde valor de mercado rapidamente. Mantenha o foco e o profissionalismo at\xe9 ao momento da assinatura da escritura ou contrato. A percep\xe7\xe3o de sucesso e organiza\xe7\xe3o \xe9 o que atrai os investidores mais qualificados.",en:" A business that neglects its management or public image in the months leading up to the sale quickly loses market value. Maintain focus and professionalism until the signing of the deed or contract. The perception of success and organization is what attracts the most qualified investors.",fr:" Une entreprise qui n\xe9glige sa gestion ou son image publique dans les mois pr\xe9c\xe9dant la vente perd rapidement de la valeur marchande. Maintenez la concentration et le professionnalisme jusqu'\xe0 la signature de l'acte ou du contrat. La perception du succ\xe8s et de l'organisation est ce qui attire les investisseurs les plus qualifi\xe9s.",de:" Ein Unternehmen, das seine Verwaltung oder sein \xf6ffentliches Image in den Monaten vor dem Verkauf vernachl\xe4ssigt, verliert schnell an Marktwert. Behalten Sie den Fokus und die Professionalit\xe4t bis zur Unterzeichnung der Urkunde oder des Vertrags bei. Die Wahrnehmung von Erfolg und Organisation zieht die qualifiziertesten Investoren an.",es:" Un negocio que descuida su gesti\xf3n o imagen p\xfablica en los meses previos a la venta pierde valor de mercado r\xe1pidamente. Mantenga el enfoque y la profesionalidad hasta la firma de la escritura o el contrato. La percepci\xf3n de \xe9xito y organizaci\xf3n es lo que atrae a los inversores m\xe1s cualificados.",zh:" 在出售前的几个月里，忽视管理或公众形象的企业会迅速失去市场价值。在签署契约或合同之前，请保持专注和专业。成功和有条理的形象是吸引最合格投资者的关键。"},trespasse_post_cta_title:{pt:"Necessita de ajuda para avaliar o seu trespasse?",en:"Do you need help evaluating your business transfer?",fr:"Avez-vous besoin d'aide pour \xe9valuer votre cession d'entreprise ?",de:"Ben\xf6tigen Sie Hilfe bei der Bewertung Ihrer Gesch\xe4fts\xfcbertragung?",es:"\xbfNecesita ayuda para evaluar su traspaso de negocio?",zh:"您需要帮助评估您的业务转让吗？"},trespasse_post_cta_desc:{pt:"O mercado comercial exige uma an\xe1lise distinta do segmento residencial. N\xf3s dispomos das ferramentas e da experi\xeancia necess\xe1rias para assegurar que o seu neg\xf3cio seja apresentado aos interlocutores certos, garantindo, desta forma, o valor que ele realmente merece.",en:"The commercial market requires a different analysis than the residential segment. We have the necessary tools and experience to ensure that your business is presented to the right people, thus guaranteeing the value it truly deserves.",fr:"Le march\xe9 commercial exige une analyse diff\xe9rente de celle du segment r\xe9sidentiel. Nous disposons des outils et de l'exp\xe9rience n\xe9cessaires pour garantir que votre entreprise soit pr\xe9sent\xe9e aux bonnes personnes, garantissant ainsi la valeur qu'elle m\xe9rite vraiment.",de:"Der gewerbliche Markt erfordert eine andere Analyse als das Wohnsegment. Wir verf\xfcgen \xfcber die notwendigen Werkzeuge und Erfahrungen, um sicherzustellen, dass Ihr Unternehmen den richtigen Leuten pr\xe4sentiert wird und somit den Wert garantiert, den es wirklich verdient.",es:"El mercado comercial requiere un an\xe1lisis diferente al del segmento residencial. Contamos con las herramientas y la experiencia necesarias para garantizar que su negocio se presente a las personas adecuadas, garantizando as\xed el valor que realmente merece.",zh:"商业市场需要的分析与住宅市场不同。我们拥有必要的工具和经验，确保您的业务能够呈现给合适的人，从而保证其真正应有的价值。"},trespasse_post_cta_card_title:{pt:"Garanta o melhor neg\xf3cio para o seu futuro.",en:"Secure the best deal for your future.",fr:"Assurez la meilleure affaire pour votre avenir.",de:"Sichern Sie sich das beste Gesch\xe4ft f\xfcr Ihre Zukunft.",es:"Asegure el mejor trato para su futuro.",zh:"为您的未来确保最好的交易。"},trespasse_post_cta_card_desc:{pt:"Vamos conversar sobre como podemos posicionar o seu trespasse de forma estrat\xe9gica e profissional.",en:"Let's talk about how we can strategically and professionally position your business transfer.",fr:"Parlons de la mani\xe8re dont nous pouvons positionner strat\xe9giquement et professionnellement votre cession d'entreprise.",de:"Lassen Sie uns dar\xfcber sprechen, wie wir Ihre Gesch\xe4fts\xfcbertragung strategisch und professionell positionieren k\xf6nnen.",es:"Hablemos de c\xf3mo podemos posicionar su traspaso de negocio de forma estrat\xe9gica y profesional.",zh:"让我们谈谈如何战略性、专业地定位您的业务转让。"},trespasse_post_cta_card_button_text:{pt:"Pedir An\xe1lise Profissional",en:"Request Professional Analysis",fr:"Demander une analyse professionnelle",de:"Professionelle Analyse anfordern",es:"Solicitar an\xe1lisis profesional",zh:"请求专业分析"},post_exclusividade_main_title:{pt:"Exclusividade: Por que \xe9 que no amor funciona e na venda da sua casa tamb\xe9m?",en:"Exclusivity: Why does it work in love and also in selling your home?",fr:"Exclusivit\xe9 : Pourquoi \xe7a marche en amour et aussi pour vendre votre maison ?",de:"Exklusivit\xe4t: Warum funktioniert sie in der Liebe und auch beim Verkauf Ihres Hauses?",es:"Exclusividad: \xbfPor qu\xe9 funciona en el amor y tambi\xe9n al vender tu casa?",zh:"独家代理：为什么它在爱情中行得通，在卖房时也同样适用？"},post_exclusividade_subtitle:{pt:'Vamos falar de elefantes na sala. Quando ouve a palavra "Exclusividade", muitos propriet\xe1rios sentem um frio na barriga, como se estivessem a assinar um contrato de casamento sem direito a div\xf3rcio. Mas a verdade \xe9 que vender uma casa em "regime aberto" (com 5 ou 6 ag\xeancias ao mesmo tempo) \xe9 o equivalente imobili\xe1rio a uma rela\xe7\xe3o poliamorosa... mas daquelas que correm mal.',en:"Let's address the elephant in the room. Many homeowners get nervous at the word 'Exclusivity.' But selling a home with an 'open listing' is the equivalent of a polyamorous relationship gone wrong.",fr:"Parlons de l'\xe9l\xe9phant dans la pi\xe8ce. Beaucoup de propri\xe9taires ont des sueurs froides au mot \xab Exclusivit\xe9 \xbb. Mais vendre une maison en \xab mandat simple \xbb est l'\xe9quivalent d'une relation polyamoureuse qui tourne mal.",de:"Sprechen wir \xfcber den Elefanten im Raum. Viele Hausbesitzer bekommen beim Wort „Exklusivit\xe4t“ ein mulmiges Gef\xfchl. Aber ein Haus mit einem „offenen Maklervertrag“ zu verkaufen, ist das \xc4quivalent einer schiefgelaufenen polyamoren Beziehung.",es:"Hablemos del elefante en la habitaci\xf3n. A muchos propietarios les da un vuelco el coraz\xf3n al o\xedr la palabra 'Exclusividad'. Pero vender una casa con un 'contrato abierto' es el equivalente a una relaci\xf3n poliamorosa que acaba mal.",zh:"我们来谈谈房间里的大象。许多房主一听到“独家代理”这个词就会感到紧张。但是，以“开放式代理”出售房屋，就相当于一段出了问题的开放式关系。"},post_exclusividade_intro:{pt:"Deixe-me explicar-lhe por que \xe9 que 'namorar' com todos os consultores da zona vai acabar por lhe deixar o cora\xe7\xe3o (e a carteira) partidos.",en:"Let me explain why 'dating' all the agents in the area will end up breaking your heart (and your wallet).",fr:"Laissez-moi vous expliquer pourquoi 'fr\xe9quenter' tous les agents du quartier finira par vous briser le cœur (et le portefeuille).",de:"Lassen Sie mich erkl\xe4ren, warum das „Dating“ mit allen Maklern in der Gegend Ihnen am Ende das Herz (und den Geldbeutel) brechen wird.",es:"Perm\xedteme explicarte por qu\xe9 'salir' con todos los agentes de la zona acabar\xe1 rompi\xe9ndote el coraz\xf3n (y la cartera).",zh:"让我来解释一下，为什么与该地区所有的中介“约会”最终会让你伤心（又伤财）。"},post_exclusividade_point1_title:{pt:"1. Quem ama tudo, n\xe3o ama ningu\xe9m",en:"1. He who loves everything, loves nothing",fr:"1. Qui aime tout, n'aime personne",de:"1. Wer alles liebt, liebt niemanden",es:"1. Quien todo lo ama, no ama a nadie",zh:"1. 爱一切者，无一真爱"},post_exclusividade_p1_main1:{pt:"No regime aberto, o consultor n\xe3o \xe9 seu 'parceiro'; ele \xe9 apenas um pretendente num speed dating desesperado. Ele sabe que, a qualquer momento, outro pode chegar e levar a comiss\xe3o.",en:"In an open listing, the agent isn't your 'partner'; he's just a suitor in a desperate speed dating session. He knows that at any moment, someone else can come along and take the commission.",fr:"Avec un mandat simple, l'agent n'est pas votre 'partenaire' ; il est juste un pr\xe9tendant dans une s\xe9ance de speed dating d\xe9sesp\xe9r\xe9e. Il sait qu'\xe0 tout moment, un autre peut arriver et prendre la commission.",de:"Bei einem offenen Maklervertrag ist der Makler nicht Ihr „Partner“; er ist nur ein Bewerber bei einem verzweifelten Speed-Dating. Er wei\xdf, dass jederzeit ein anderer kommen und die Provision einstreichen kann.",es:"En un contrato abierto, el agente no es tu 'socio'; es solo un pretendiente en una sesi\xf3n de citas r\xe1pidas desesperada. Sabe que, en cualquier momento, otro puede llegar y llevarse la comisi\xf3n.",zh:"在开放式代理中，中介不是你的“伴侣”；他只是一个绝望的快速约会中的追求者。他知道，随时都可能有别人出现并拿走佣金。"},post_exclusividade_p1_impact:{pt:"O resultado? Ele n\xe3o investe em si. N\xe3o h\xe1 jantar \xe0 luz de velas (fotos profissionais), n\xe3o h\xe1 presentes caros (an\xfancios premium). Ele faz o m\xednimo e espera ter sorte.",en:"The result? He doesn't invest in you. No candlelight dinners (professional photos), no expensive gifts (premium ads). He does the bare minimum and hopes for the best.",fr:"Le r\xe9sultat ? Il n'investit pas en vous. Pas de d\xeeners aux chandelles (photos professionnelles), pas de cadeaux co\xfbteux (annonces premium). Il fait le strict minimum et esp\xe8re avoir de la chance.",de:"Das Ergebnis? Er investiert nicht in Sie. Keine Candle-Light-Dinner (professionelle Fotos), keine teuren Geschenke (Premium-Anzeigen). Er macht das N\xf6tigste und hofft auf Gl\xfcck.",es:"\xbfEl resultado? No invierte en ti. No hay cenas a la luz de las velas (fotos profesionales), ni regalos caros (anuncios pr\xe9mium). Hace lo m\xednimo y espera tener suerte.",zh:"结果呢？他不会在你身上投资。没有烛光晚餐（专业摄影），没有昂贵的礼物（付费广告）。他只做最基本的，然后指望运气。"},post_exclusividade_p1_solution:{pt:"No regime de exclusividade, eu sou o parceiro fiel: invisto tudo para que a nossa 'rela\xe7\xe3o' (a venda) seja um sucesso.",en:"With an exclusive agreement, I am the faithful partner: I invest everything to make our 'relationship' (the sale) a success.",fr:"Avec un mandat exclusif, je suis le partenaire fid\xe8le : j'investis tout pour que notre 'relation' (la vente) soit un succ\xe8s.",de:"Bei einer Exklusivvereinbarung bin ich der treue Partner: Ich investiere alles, damit unsere „Beziehung“ (der Verkauf) ein Erfolg wird.",es:"Con un contrato de exclusividad, soy el socio fiel: lo invierto todo para que nuestra 'relaci\xf3n' (la venta) sea un \xe9xito.",zh:"而在独家协议下，我则是忠实的伙伴：我会投入一切，确保我们的“关系”（即销售）取得成功。"},post_exclusividade_point2_title:{pt:"2. O im\xf3vel que 'anda na boca de todos'",en:"2. The property that's 'on everyone's lips'",fr:"2. Le bien qui est 'sur toutes les l\xe8vres'",de:"2. Die Immobilie, die 'in aller Munde' ist",es:"2. La propiedad que 'est\xe1 en boca de todos'",zh:"2. “家喻户晓”的房产"},post_exclusividade_p2_main:{pt:"J\xe1 viu aquele perfil no Tinder que aparece 10 vezes com fotos diferentes e descri\xe7\xf5es contradit\xf3rias? \xc9 o que acontece \xe0 sua casa no regime aberto.",en:"Have you ever seen that Tinder profile that shows up 10 times with different photos and contradictory descriptions? That's what happens to your house with an open listing.",fr:"Avez-vous d\xe9j\xe0 vu ce profil Tinder qui appara\xeet 10 fois avec des photos diff\xe9rentes et des descriptions contradictoires ? C'est ce qui arrive \xe0 votre maison avec un mandat simple.",de:"Haben Sie schon einmal dieses Tinder-Profil gesehen, das 10 Mal mit verschiedenen Fotos und widerspr\xfcchlichen Beschreibungen auftaucht? Das passiert mit Ihrem Haus bei einem offenen Maklervertrag.",es:"\xbfHas visto alguna vez ese perfil de Tinder que aparece 10 veces con fotos diferentes y descripciones contradictorias? Eso es lo que le pasa a tu casa con un contrato abierto.",zh:"你见过那个在Tinder上出现10次，每次照片不同、描述还相互矛盾的个人资料吗？这就是你的房子在开放式代理下会发生的情况。"},post_exclusividade_p2_error1:{pt:"Num an\xfancio custa 300k, noutro 295k, num as fotos s\xe3o escuras, noutro a descri\xe7\xe3o est\xe1 errada.",en:"In one ad it costs 300k, in another 295k. In one, the photos are dark, in another, the description is wrong.",fr:"Dans une annonce, elle co\xfbte 300k, dans une autre 295k. Dans l'une, les photos sont sombres, dans l'autre, la description est fausse.",de:"In einer Anzeige kostet es 300k, in einer anderen 295k. In einer sind die Fotos dunkel, in einer anderen ist die Beschreibung falsch.",es:"En un anuncio cuesta 300k, en otro 295k. En uno las fotos son oscuras, en otro la descripci\xf3n es incorrecta.",zh:"一个广告上标价30万，另一个标价29.5万。一个广告的照片很暗，另一个的描述是错的。"},post_exclusividade_p2_error2:{pt:'O que o comprador pensa? "Esta casa deve ter um problema, est\xe1 desesperada por aten\xe7\xe3o."',en:'What does the buyer think? "This house must have a problem, it\'s desperate for attention."',fr:"Que pense l'acheteur ? \xab Cette maison doit avoir un probl\xe8me, elle cherche d\xe9sesp\xe9r\xe9ment l'attention. \xbb",de:"Was denkt der K\xe4ufer? „Dieses Haus muss ein Problem haben, es ist verzweifelt auf der Suche nach Aufmerksamkeit.“",es:'\xbfQu\xe9 piensa el comprador? "Esta casa debe de tener um problema, est\xe1 desesperada por llamar la atenci\xf3n".',zh:"买家会怎么想？“这房子肯定有问题，它太渴望关注了。”"},post_exclusividade_p2_solution:{pt:"A exclusividade d\xe1 postura e valor. \xc9 a diferen\xe7a entre ser uma oportunidade \xfanica ou ser o 'prato do dia' que ningu\xe9m quer.",en:"Exclusivity gives it posture and value. It's the difference between being a unique opportunity and being the 'special of the day' that no one wants.",fr:"L'exclusivit\xe9 donne de la prestance et de la valeur. C'est la diff\xe9rence entre \xeatre une opportunit\xe9 unique et \xeatre le 'plat du jour' que personne ne veut.",de:"Exklusivit\xe4t verleiht Haltung und Wert. Es ist der Unterschied zwischen einer einmaligen Gelegenheit und dem „Tagesgericht“, das niemand will.",es:"La exclusividad le da prestigio y valor. Es la diferencia entre ser una oportunidad \xfanica y ser el 'plato del d\xeda' que nadie quiere.",zh:"独家代理赋予了房产应有的地位和价值。这是成为一个独特机会与成为无人问津的“每日特价”之间的区别。"},post_exclusividade_point3_title:{pt:"3. 'N\xe3o \xe9s tu, sou eu' (A gest\xe3o de expectativas)",en:"3. 'It's not you, it's me' (Managing expectations)",fr:"3. \xab Ce n'est pas toi, c'est moi \xbb (La gestion des attentes)",de:"3. „Es liegt nicht an dir, es liegt an mir“ (Erwartungsmanagement)",es:"3. 'No eres t\xfa, soy yo' (La gesti\xf3n de expectativas)",zh:"3. ‘不是你的问题，是我的问题’（期望管理）"},post_exclusividade_p3_main:{pt:"Tentar gerir 5 consultores ao mesmo tempo \xe9 como tentar manter 5 rela\xe7\xf5es em paralelo sem que ningu\xe9m se cruze \xe0 porta de casa. \xc9 exaustivo, gera confus\xe3o de mensagens e, no final, algu\xe9m vai mentir-lhe para conseguir o seu 'sim'.",en:"Trying to manage 5 agents at the same time is like trying to maintain 5 parallel relationships without anyone bumping into each other at the door. It's exhausting, creates confusing messages, and in the end, someone will lie to get your 'yes'.",fr:"Essayer de g\xe9rer 5 agents en m\xeame temps, c'est comme essayer d'entretenir 5 relations parall\xe8les sans que personne ne se croise \xe0 la porte. C'est \xe9puisant, cela cr\xe9e des messages confus et, \xe0 la fin, quelqu'un vous mentira pour obtenir votre 'oui'.",de:"Der Versuch, 5 Makler gleichzeitig zu managen, ist wie der Versuch, 5 parallele Beziehungen zu f\xfchren, ohne dass sich jemand an der T\xfcr \xfcber den Weg l\xe4uft. Es ist anstrengend, f\xfchrt zu verwirrenden Nachrichten und am Ende wird Ihnen jemand l\xfcgen, um Ihr „Ja“ zu bekommen.",es:"Intentar gestionar a 5 agentes a la vez es como intentar mantener 5 relaciones paralelas sin que nadie se cruce en la puerta. Es agotador, genera mensajes confusos y, al final, alguien te mentir\xe1 para conseguir tu 's\xed'.",zh:"同时管理5个中介，就像试图同时维持5段平行关系，还要确保没人在门口撞见。这让人筋疲力尽，信息混乱，而且到最后，总会有人为了得到你的“同意”而对你撒谎。"},post_exclusividade_p3_solution:{pt:"Com exclusividade, a comunica\xe7\xe3o \xe9 direta. Sem joguinhos. Eu defendo o seu pre\xe7o como quem defende a honra da fam\xedlia.",en:"With exclusivity, communication is direct. No games. I defend your price like someone defending the family's honor.",fr:"Avec l'exclusivit\xe9, la communication est directe. Pas de petits jeux. Je d\xe9fends votre prix comme on d\xe9fend l'honneur de la famille.",de:"Mit Exklusivit\xe4t ist die Kommunikation direkt. Keine Spielchen. Ich verteidige Ihren Preis, als w\xfcrde ich die Ehre der Familie verteidigen.",es:"Con la exclusividad, la comunicaci\xf3n es directa. Sin jueguecitos. Defiendo tu precio como quien defiende el honor de la familia.",zh:"有了独家代理，沟通是直接的。没有花招。我捍卫你的价格，就像捍卫家族荣誉一样。"},post_exclusividade_point4_title:{pt:"4. A trai\xe7\xe3o do pre\xe7o",en:"4. The price betrayal",fr:"4. La trahison du prix",de:"4. Der Preisverrat",es:"4. La traici\xf3n del pre\xe7o",zh:"4. 价格的背叛"},post_exclusividade_p4_error:{pt:"No regime aberto, os consultores competem entre si para ver quem lhe traz a proposta primeiro — mesmo que seja uma proposta baixa. Eles n\xe3o querem o melhor pre\xe7o para si; querem fechar o neg\xf3cio antes do 'vizinho'.",en:"In an open listing, agents compete with each other to see who brings you the first offer—even if it's a low one. They don't want the best price for you; they want to close the deal before the 'neighbor' does.",fr:"Avec un mandat simple, les agents se font concurrence pour voir qui vous apportera la premi\xe8re offre, m\xeame si elle est basse. Ils ne veulent pas le meilleur prix pour vous ; ils veulent conclure l'affaire avant le 'voisin'.",de:"Bei einem offenen Maklervertrag konkurrieren die Makler untereinander, um zu sehen, wer Ihnen das erste Angebot bringt – auch wenn es ein niedriges ist. Sie wollen nicht den besten Preis f\xfcr Sie; sie wollen das Gesch\xe4ft vor dem „Nachbarn“ abschlie\xdfen.",es:"En un contrato abierto, los agentes compiten entre s\xed para ver qui\xe9n te trae la primera oferta, aunque sea baja. No quieren el mejor precio para ti; quieren cerrar el trato antes que el 'vecino'.",zh:"在开放式代理中，中介们相互竞争，看谁能第一个给你带来报价——即使是个低价。他们不想要为你争取最好的价格；他们只想在“邻居”之前完成交易。"},post_exclusividade_p4_solution:{pt:"Na exclusividade, eu estou no seu barco. O meu foco n\xe3o \xe9 ganhar a corrida aos outros, \xe9 levar o seu barco ao porto seguro pelo valor mais alto poss\xedvel.",en:"With exclusivity, I'm in your boat. My focus isn't to win the race against others; it's to get your boat to a safe harbor at the highest possible value.",fr:"Avec l'exclusivit\xe9, je suis dans votre bateau. Mon objectif n'est pas de gagner la course contre les autres ; c'est d'amener votre bateau \xe0 bon port \xe0 la valeur la plus \xe9lev\xe9e possible.",de:"Bei Exklusivit\xe4t sitze ich mit Ihnen im selben Boot. Mein Fokus liegt nicht darauf, das Rennen gegen andere zu gewinnen; es geht darum, Ihr Boot zum h\xf6chstm\xf6glichen Wert in einen sicheren Hafen zu bringen.",es:"Con la exclusividad, estoy en tu barco. Mi objetivo n\xe3o es ganar la carrera a los dem\xe1s; es llevar tu barco a buen puerto por el mayor valor posible.",zh:"在独家代理下，我和你在同一条船上。我的重点不是赢得与其他人的比赛，而是以尽可能高的价值将你的船带到安全的港湾。"},post_exclusividade_conclusion_title:{pt:"Conclus\xe3o: Casamos ou vamos s\xf3 dar uma volta?",en:"Conclusion: Are we getting married or just going for a spin?",fr:"Conclusion : On se marie ou on fait juste un tour ?",de:"Fazit: Heiraten wir oder drehen wir nur eine Runde?",es:"Conclusi\xf3n: \xbfNos casamos o solo damos una vuelta?",zh:"结论：我们是结婚还是只是随便玩玩？"},post_exclusividade_conclusion_p:{pt:"Vender uma casa \xe9 um compromisso s\xe9rio. Pode andar a 'saltitar' de ag\xeancia em ag\xeancia e ver o seu im\xf3vel ficar 'queimado' no mercado, ou pode escolher um parceiro que se dedica a 100% \xe0 sua felicidade financeira.",en:"Selling a house is a serious commitment. You can 'hop' from agency to agency and watch your property get 'burned' on the market, or you can choose a partner who is 100% dedicated to your financial happiness.",fr:"Vendre une maison est un engagement s\xe9rieux. Vous pouvez 'sautiller' d'agence en agence et voir votre bien se 'griller' sur le march\xe9, ou vous pouvez choisir un partenaire qui se consacre \xe0 100% \xe0 votre bonheur financier.",de:"Ein Haus zu verkaufen ist eine ernste Verpflichtung. Sie k\xf6nnen von Agentur zu Agentur „springen“ und zusehen, wie Ihre Immobilie auf dem Markt „verbrennt“, oder Sie k\xf6nnen einen Partner w\xe4hlen, der sich zu 100 % Ihrem finanziellen Gl\xfcck widmet.",es:"Vender una casa es un compromiso serio. Puedes ir 'saltando' de agencia en agencia y ver c\xf3mo tu propiedad se 'quema' en el mercado, o puedes elegir un socio que se dedique al 100% a tu felicidad financiera.",zh:"卖房子是一项严肃的承诺。你可以从一个中介“跳槽”到另一个中介，眼睁睁地看着你的房产在市场上“被消耗掉”，或者你可以选择一个100%致力于你财务幸福的合作伙伴。"},post_exclusividade_cta_title:{pt:"Quer algu\xe9m que apenas 'd\xea uns toques' no seu an\xfancio, ou quer um Consultor fiel que luta pelos seus interesses at\xe9 ao fim?",en:"Do you want someone who just 'tinkers' with your ad, or do you want a loyal Consultant who fights for your interests until the end?",fr:"Voulez-vous quelqu'un qui 'bricole' simplement votre annonce, ou voulez-vous un consultant loyal qui se bat pour vos int\xe9r\xeats jusqu'au bout ?",de:"Wollen Sie jemanden, der nur an Ihrer Anzeige „herumbastelt“, oder wollen Sie einen loyalen Berater, der bis zum Ende f\xfcr Ihre Interessen k\xe4mpft?",es:"\xbfQuieres a alguien que solo 'retoque' tu anuncio, o quieres un consultor leal que luche por tus intereses hasta el final?",zh:"你是想要一个只会“修修补补”你广告的人，还是想要一个忠诚的顾问，为你争取利益直到最后？"},post_exclusividade_cta_button_text:{pt:"Quero um parceiro de confian\xe7a",en:"I want a trusted partner",fr:"Je veux un partenaire de confiance",de:"Ich m\xf6chte einen vertrauensw\xfcrdigen Partner",es:"Quiero un socio de confianza",zh:"我想要一个值得信赖的伙伴"},post_investir_main_title:{pt:"Os Melhores Bairros de Lisboa para Investir em 2026: Onde Est\xe1 a Valoriza\xe7\xe3o Real?",en:"The Best Neighborhoods in Lisbon to Invest in 2026: Where is the Real Appreciation?",fr:"Les Meilleurs Quartiers de Lisbonne pour Investir en 2026 : O\xf9 se Trouve la Vraie Valorisation ?",de:"Die besten Stadtteile Lissabons f\xfcr Investitionen im Jahr 2026: Wo liegt die echte Wertsteigerung?",es:"Los Mejores Barrios de Lisboa para Invertir en 2026: \xbfD\xf3nde est\xe1 la Valorizaci\xf3n Real?",zh:"2026年里斯本最值得投资的社区：真正的增值潜力在哪里？"},post_investir_subtitle:{pt:"No mercado imobili\xe1rio, os n\xfameros n\xe3o mentem. Se pretende investir em Lisboa, \xe9 fundamental analisar a evolu\xe7\xe3o m\xe9trica da cidade para compreender o potencial de retorno.",en:"In the real estate market, numbers don't lie. If you plan to invest in Lisbon, it is essential to analyze the city's metric evolution to understand the potential for return.",fr:"Sur le march\xe9 immobilier, les chiffres ne mentent pas. Si vous pr\xe9voyez d'investir \xe0 Lisbonne, il est essentiel d'analyser l'\xe9volution m\xe9trique de la ville pour comprendre le potentiel de retour sur investissement.",de:"Auf dem Immobilienmarkt l\xfcgen die Zahlen nicht. Wenn Sie in Lissabon investieren m\xf6chten, ist es unerl\xe4sslich, die metrische Entwicklung der Stadt zu analysieren, um das Renditepotenzial zu verstehen.",es:"En el mercado inmobiliario, los n\xfameros no mienten. Si planea invertir en Lisboa, es fundamental analizar a evoluci\xf3n m\xe9trica de la ciudad para comprender el potencial de retorno.",zh:"在房地产市场，数字不会说谎。如果您打算在里斯本投资，分析城市的各项指标演变以了解回报潜力至关重要。"},post_investir_intro:{pt:"Em 2026, assistimos a uma Lisboa de duas velocidades: o centro consolidado e as periferias em explos\xe3o de valor. Abaixo, detalhamos os indicadores que fundamentam as nossas escolhas para este ano.",en:"In 2026, we are witnessing a two-speed Lisbon: the consolidated center and the peripheries experiencing a value explosion. Below, we detail the indicators that support our choices for this year.",fr:"En 2026, nous assistons \xe0 un Lisbonne \xe0 deux vitesses : le centre consolid\xe9 et les p\xe9riph\xe9ries en pleine explosion de valeur. Ci-dessous, nous d\xe9taillons les indicateurs qui justifient nos choix pour cette ann\xe9e.",de:"Im Jahr 2026 erleben wir ein Lissabon mit zwei Geschwindigkeiten: das konsolidierte Zentrum und die Peripherien, die eine Wertexplosion erleben. Nachfolgend detaillieren wir die Indikatoren, die unsere Entscheidungen f\xfcr dieses Jahr untermauern.",es:"En 2026, asistimos a una Lisboa de dos velocidades: el centro consolidado y las periferias en explosi\xf3n de valor. A continuaci\xf3n, detallamos los indicadores que fundamentan nuestras elecciones para este ano.",zh:"2026年，我们见证了一个双速发展的里斯本：成熟的市中心和价值迅速增长的周边地区。下面，我们详细说明了支撑我们今年选择的各项指标。"},post_investir_h2_1:{pt:"A For\xe7a dos N\xfameros: O que mudou nos \xfaltimos 5 anos?",en:"The Power of Numbers: What has changed in the last 5 years?",fr:"La Force des Chiffres : Qu'est-ce qui a chang\xe9 au cours des 5 derni\xe8res ann\xe9es ?",de:"Die Macht der Zahlen: Was hat sich in den letzten 5 Jahren ver\xe4ndert?",es:"La Fuerza de los N\xfameros: \xbfQu\xe9 ha cambiado en los \xfaltimos 5 a\xf1os?",zh:"数字的力量：过去5年发生了什么变化？"},post_investir_p1:{pt:"Segundo o \xcdndice de Pre\xe7os da Habita\xe7\xe3o (IPHab) do INE, o mercado de Lisboa registou uma trajet\xf3ria hist\xf3rica. Entre 2020 e 2025, o pre\xe7o mediano de venda na cidade subiu, em m\xe9dia, 68%, mas em freguesias espec\xedficas o salto foi muito superior.",en:"According to the INE's Housing Price Index (IPHab), the Lisbon market has registered a historic trajectory. Between 2020 and 2025, the median selling price in the city rose by an average of 68%, but in specific parishes, the jump was much higher.",fr:"Selon l'Indice des Prix de l'Habitation (IPHab) de l'INE, le march\xe9 de Lisbonne a enregistr\xe9 une trajectoire historique. Entre 2020 et 2025, le prix de vente m\xe9dian dans la ville a augment\xe9 en moyenne de 68 %, mais dans certaines paroisses, le bond a \xe9t\xe9 beaucoup plus important.",de:"Laut dem Wohnimmobilienpreisindex (IPHab) des INE hat der Lissabonner Markt eine historische Entwicklung verzeichnet. Zwischen 2020 und 2025 stieg der mittlere Verkaufspreis in der Stadt um durchschnittlich 68 %, in bestimmten Gemeinden war der Anstieg jedoch weitaus h\xf6her.",es:"Seg\xfan el \xcdndice de Precios de la Vivienda (IPHab) del INE, el mercado de Lisboa ha registrado una trayectoria hist\xf3rica. Entre 2020 et 2025, el precio medio de venta en la ciudad subi\xf3, de media, un 68%, pero en parroquias espec\xedficas el salto fue mucho mayor.",zh:"根据国家统计局（INE）的房价指数（IPHab），里斯本市场经历了历史性的增长轨迹。在2020年至2025年间，该市的销售价格中位数平均上涨了68％，但在特定行政区的涨幅要高得多。"},post_investir_h3_1:{pt:"As zonas que lideraram a valoriza\xe7\xe3o foram:",en:"The areas that led the appreciation were:",fr:"Les zones qui ont men\xe9 la valorisation ont \xe9t\xe9 :",de:"Die Gebiete, die die Wertsteigerung anf\xfchrten, waren:",es:"Las zonas que lideraron la valorizaci\xf3n fueron:",zh:"引领增值的区域是："},post_investir_li1:{pt:"Marvila: Registou uma subida superior a 95% no valor por m\xb2 nos \xfaltimos 6 anos, impulsionada pela convers\xe3o de armaz\xe9ns em habita\xe7\xe3o de luxo.",en:"Marvila: Recorded an increase of over 95% in value per m\xb2 in the last 6 years, driven by the conversion of warehouses into luxury housing.",fr:"Marvila : A enregistr\xe9 une augmentation de plus de 95 % de la valeur par m\xb2 au cours des 6 derni\xe8res ann\xe9es, port\xe9e par la conversion d'entrep\xf4ts en logements de luxe.",de:"Marvila: Verzeichnete in den letzten 6 Jahren einen Wertzuwachs von \xfcber 95 % pro m\xb2, angetrieben durch die Umwandlung von Lagerh\xe4usern in Luxuswohnungen.",es:"Marvila: Registr\xf3 una subida superior al 95% en el valor por m\xb2 en los \xfaltimos 6 a\xf1os, impulsada por la conversi\xf3n de almacenes en viviendas de lujo.",zh:"马维拉（Marvila）：过去6年中，每平方米价值增长超过95％，这得益于仓库改建为豪华住宅。"},post_investir_li2:{pt:"Arroios: O valor mediano de avalia\xe7\xe3o banc\xe1ria subiu 14% apenas no \xfaltimo ano, consolidando-se como uma zona de alta liquidez.",en:"Arroios: The median bank appraisal value rose by 14% in the last year alone, consolidating its position as a high-liquidity area.",fr:"Arroios : La valeur m\xe9diane d'\xe9valuation bancaire a augment\xe9 de 14 % rien que l'ann\xe9e derni\xe8re, se consolidant comme une zone \xe0 forte liquidit\xe9.",de:"Arroios: Der mittlere Bankbewertungswert stieg allein im letzten Jahr um 14 % und festigte seine Position als hochliquides Gebiet.",es:"Arroios: El valor mediano de tasaci\xf3n banc\xe1ria subi\xf3 un 14% solo en el \xfaltimo a\xf1o, consolid\xe1ndose como una zona de alta liquidez.",zh:"阿罗约斯（Arroios）：仅去年一年，银行评估中值就上涨了14％，巩固了其作为高流动性区域的地位。"},post_investir_li3:{pt:"Benfica: Surpreendeu o mercado com uma valoriza\xe7\xe3o acumulada de 55% desde 2020, \xe0 medida que a classe m\xe9dia procurava alternativas ao centro.",en:"Benfica: Surprised the market with an accumulated appreciation of 55% since 2020, as the middle class sought alternatives to the city center.",fr:"Benfica : A surpris le march\xe9 avec une appr\xe9ciation cumul\xe9e de 55 % depuis 2020, alors que la classe moyenne cherchait des alternatives au centre-ville.",de:"Benfica: \xdcberraschte den Markt mit einer kumulierten Wertsteigerung von 55 % seit 2020, da die Mittelschicht nach Alternativen zum Stadtzentrum suchte.",es:"Benfica: Sorprendi\xf3 al mercado con una valorizaci\xf3n acumulada del 55% desde 2020, a medida que la clase media buscaba alternativas al centro.",zh:"本菲卡（Benfica）：自2020年以来，随着中产阶级寻求市中心以外的选择，该区域累计增值55％，令市场感到意外。"},post_investir_h2_2:{pt:"Exemplo Pr\xe1tico: O Poder da Valoriza\xe7\xe3o Acumulada",en:"Practical Example: The Power of Accumulated Appreciation",fr:"Exemple Pratique : Le Pouvoir de la Valorisation Cumul\xe9e",de:"Praktisches Beispiel: Die Kraft der kumulierten Wertsteigerung",es:"Ejemplo Pr\xe1ctico: El Poder de la Valorizaci\xf3n Acumulada",zh:"实例分析：累计增值的力量"},post_investir_p2:{pt:"Para que se compreenda o impacto real destes indicadores, vejamos um cen\xe1rio baseado nos valores reais de transa\xe7\xe3o apurados pelo INE:",en:"To understand the real impact of these indicators, let's look at a scenario based on the actual transaction values reported by INE:",fr:"Pour comprendre l'impact r\xe9el de ces indicateurs, examinons un sc\xe9nario bas\xe9 sur les valeurs de transaction r\xe9elles rapport\xe9es par l'INE :",de:"Um die tats\xe4chlichen Auswirkungen dieser Indikatoren zu verstehen, betrachten wir ein Szenario, das auf den vom INE gemeldeten tats\xe4chlichen Transaktionswerten basiert:",es:"Para comprender el impacto real de estos indicadores, veamos un escenario basado en los valores de transacci\xf3n reales reportados por el INE:",zh:"为了解这些指标的实际影响，让我们看一个基于国家统计局（INE）报告的实际交易价值的情景："},post_investir_card_title:{pt:"Cen\xe1rio de Investimento:",en:"Investment Scenario:",fr:"Sc\xe9nario d'Investissement :",de:"Investitionsszenario:",es:"Escenario de Inversi\xf3n:",zh:"投资情景："},post_investir_card_item1_label:{pt:"Compra em 2020:",en:"Purchase in 2020:",fr:"Achat en 2020 :",de:"Kauf im Jahr 2020:",es:"Compra en 2020:",zh:"2020年购买："},post_investir_card_item1_value:{pt:"Apartamento por 200.000 € (valor mediano para T1/T2 em Penha de Fran\xe7a/Benfica).",en:"Apartment for €200,000 (median value for a T1/T2 in Penha de Fran\xe7a/Benfica).",fr:"Appartement pour 200 000 € (valeur m\xe9diane pour un T1/T2 \xe0 Penha de Fran\xe7a/Benfica).",de:"Wohnung f\xfcr 200.000 € (Medianwert f\xfcr eine T1/T2 in Penha de Fran\xe7a/Benfica).",es:"Apartamento por 200.000 € (valor medio para un T1/T2 en Penha de Fran\xe7a/Benfica).",zh:"公寓价格200,000欧元（Penha de Fran\xe7a/Benfica地区一室或两室公寓的中位价）。"},post_investir_card_item2_label:{pt:"Valoriza\xe7\xe3o Real:",en:"Real Appreciation:",fr:"Valorisation R\xe9elle :",de:"Reale Wertsteigerung:",es:"Valorizaci\xf3n Real:",zh:"实际增值："},post_investir_card_item2_value:{pt:"Com a subida m\xe9dia anual e o pico de 17,7% em 2025, o im\xf3vel valorizou no m\xednimo 72% at\xe9 2026.",en:"With the average annual increase and the 17.7% peak in 2025, the property appreciated by at least 72% by 2026.",fr:"Avec l'augmentation annuelle moyenne et le pic de 17,7 % en 2025, le bien s'est appr\xe9ci\xe9 d'au moins 72 % d'ici 2026.",de:"Mit dem durchschnittlichen j\xe4hrlichen Anstieg und dem H\xf6chststand von 17,7 % im Jahr 2025 hat die Immobilie bis 2026 um mindestens 72 % an Wert gewonnen.",es:"Con la subida media anual y el pico del 17,7% en 2025, la propiedad se ha revalorizado al menos un 72% hasta 2026.",zh:"考虑到年均增长和2025年17.7%的峰值，到2026年该房产至少增值72%。"},post_investir_card_item3_label:{pt:"Valor de Mercado Atual:",en:"Current Market Value:",fr:"Valeur Marchande Actuelle :",de:"Aktueller Marktwert:",es:"Valor de Mercado Atual:",zh:"当前市场价值："},post_investir_card_item3_value:{pt:"O mesmo im\xf3vel vale hoje aproximadamente 344.000 €.",en:"The same property is now worth approximately €344,000.",fr:"Le m\xeame bien vaut aujourd'hui environ 344 000 €.",de:"Dieselbe Immobilie ist heute ungef\xe4hr 344.000 € wert.",es:"La mesma propiedad vale hoy aproximadamente 344.000 €.",zh:"如今同一房产的价值约为344,000欧元。"},post_investir_card_item4_label:{pt:"Ganho de Capital:",en:"Capital Gain:",fr:"Plus-value :",de:"Kapitalgewinn:",es:"Ganancia de Capital:",zh:"资本收益："},post_investir_card_item4_value:{pt:"Um lucro bruto de 144.000 € em 6 anos.",en:"A gross profit of €144,000 in 6 years.",fr:"Un b\xe9n\xe9fice brut de 144 000 € en 6 ans.",de:"Ein Bruttogewinn von 144.000 € in 6 Jahren.",es:"Un beneficio bruto de 144.000 € en 6 a\xf1os.",zh:"6年内毛利润144,000欧元。"},post_investir_h2_3:{pt:"Onde investir agora em 2026?",en:"Where to invest now in 2026?",fr:"O\xf9 investir maintenant en 2026 ?",de:"Wo soll man jetzt im Jahr 2026 investieren?",es:"\xbfD\xf3nde invertir ahora en 2026?",zh:"2026年现在投资哪里？"},post_investir_p3:{pt:"Para assegurar que o seu capital tenha o mesmo desempenho, a nossa an\xe1lise foca-se em zonas onde o pre\xe7o por m\xb2 ainda permite margem de progress\xe3o:",en:"To ensure your capital performs similarly, our analysis focuses on areas where the price per m\xb2 still allows for growth:",fr:"Pour garantir que votre capital performe de la m\xeame mani\xe8re, notre analyse se concentre sur les zones o\xf9 le prix au m\xb2 permet encore une marge de progression :",de:"Um sicherzustellen, dass Ihr Kapital eine \xe4hnliche Performance erzielt, konzentriert sich unsere Analyse auf Gebiete, in denen der Preis pro m\xb2 noch Wachstumspotenzial bietet:",es:"Para asegurar que su capital tenga um rendimiento similar, nuestro an\xe1lisis se centra en zonas donde el precio por m\xb2 todav\xeda permite margen de progresi\xf3n:",zh:"为确保您的资本有相似表现，我们的分析重点关注每平方米价格仍有增长空间的区域："},post_investir_h3_2:{pt:"Zonas com Potencial:",en:"Areas with Potential:",fr:"Zones \xe0 Potentiel :",de:"Gebiete mit Potenzial:",es:"Zonas con Potencial:",zh:"有潜力的区域："},post_investir_li4:{pt:"Beato e Xabregas: O pre\xe7o mediano ainda se encontra cerca de 20% abaixo da Estrela ou Miseric\xf3rdia, apesar de estarem a apenas 10 minutos de dist\xe2ncia. \xc9 aqui que prevemos o maior ganho de capital at\xe9 2030.",en:"Beato and Xabregas: The median price is still about 20% below Estrela or Miseric\xf3rdia, despite being only 10 minutes away. This is where we predict the largest capital gain by 2030.",fr:"Beato et Xabregas : Le prix m\xe9dian est encore environ 20 % inf\xe9rieur \xe0 celui d'Estrela ou de Miseric\xf3rdia, bien qu'ils ne soient qu'\xe0 10 minutes. C'est ici que nous pr\xe9voyons la plus grande plus-value d'ici 2030.",de:"Beato und Xabregas: Der Medianpreis liegt immer noch etwa 20 % unter dem von Estrela oder Miseric\xf3rdia, obwohl sie nur 10 Minuten entfernt sind. Hier prognostizieren wir den gr\xf6\xdften Kapitalgewinn bis 2030.",es:"Beato y Xabregas: El precio medio sigue estando un 20% por debajo de Estrela o Miseric\xf3rdia, a pesar de estar a solo 10 minutos de distancia. Aqu\xed es donde prevemos la maior ganancia de capital para 2030.",zh:"贝阿托（Beato）和沙布雷加斯（Xabregas）：尽管距离埃什特雷拉（Estrela）或米塞里科迪亚（Miseric\xf3rdia）仅10分钟路程，但其中位价仍低约20％。我们预测到2030年这里将实现最大的资本收益。"},post_investir_li5:{pt:"Alc\xe2ntara: Com o projeto da nova linha de Metro a avan\xe7ar, os indicadores de procura subiram 22% no \xfaltimo semestre, sinalizando uma subida iminente de pre\xe7os.",en:"Alc\xe2ntara: With the new Metro line project advancing, demand indicators rose by 22% in the last semester, signaling an imminent price increase.",fr:"Alc\xe2ntara : Avec l'avancement du projet de la nouvelle ligne de m\xe9tro, les indicateurs de demande ont augment\xe9 de 22 % au dernier semestre, signalant une augmentation imminente des prix.",de:"Alc\xe2ntara: Mit dem fortschreitenden Projekt der neuen U-Bahn-Linie stiegen die Nachfrageindikatoren im letzten Halbjahr um 22 %, was auf einen bevorstehenden Preisanstieg hindeutet.",es:"Alc\xe2ntara: Con el avance del proyecto de la nueva l\xednea de metro, los indicadores de demanda subieron un 22% en el \xfaltimo semestre, se\xf1alando uma inminente subida de precios.",zh:"阿尔坎塔拉（Alc\xe2ntara）：随着新地铁线项目的推进，需求指标在过去半年上涨了22％，预示着价格即将上涨。"},post_investir_li6:{pt:"Campolide: A proximidade ao centro financeiro e \xe0s Amoreiras garante uma rentabilidade de arrendamento (yield) est\xe1vel, situada atualmente nos 5% a 6% brutos.",en:"Campolide: Proximity to the financial center and Amoreiras guarantees a stable rental yield, currently between 5% and 6% gross.",fr:"Campolide : La proximit\xe9 du centre financier et d'Amoreiras garantit un rendement locatif stable, actuellement compris entre 5 % et 6 % brut.",de:"Campolide: Die N\xe4he zum Finanzzentrum und zu Amoreiras garantiert eine stabile Mietrendite, die derzeit zwischen 5 % und 6 % brutto liegt.",es:"Campolide: La proximidad al centro financiero y a las Amoreiras garantiza una rentabilidad por alquiler (yield) estable, situada actualmente entre el 5% y el 6% bruto.",zh:"坎波利德（Campolide）：靠近金融中心和Amoreiras购物中心，保证了稳定的租金收益率，目前毛收益率在5％至6％之间。"},post_investir_h2_4:{pt:"Transpar\xeancia e Rigor Cient\xedfico",en:"Transparency and Scientific Rigor",fr:"Transparence et Rigueur Scientifique",de:"Transparenz und wissenschaftliche Strenge",es:"Transparencia y Rigor Cient\xedfico",zh:"透明度与科学严谨性"},post_investir_p4:{pt:"Toda a informa\xe7\xe3o aqui apresentada baseia-se na consulta direta das Estat\xedsticas de Pre\xe7os da Habita\xe7\xe3o ao N\xedvel Local do INE e nos dados de avalia\xe7\xe3o banc\xe1ria.",en:"All information presented here is based on direct consultation of INE's Local Level Housing Price Statistics and bank appraisal data.",fr:"Toutes les informations pr\xe9sent\xe9es ici sont bas\xe9es sur la consultation directe des Statistiques des Prix du Logement au Niveau Local de l'INE et des donn\xe9es d'\xe9valuation bancaire.",de:"Alle hier dargestellten Informationen basieren auf der direkten Konsultation der Wohnimmobilienpreisstatistiken auf lokaler Ebene des INE und den Daten der Bankbewertung.",es:"Toda la informaci\xf3n aqu\xed presentada se basa en la consulta directa de las Estad\xedsticas de Precios de la Vivienda a Nivel Local del INE y en los datos de tasa\xe7\xe3o banc\xe1ria.",zh:"此处提供的所有信息均基于对国家统计局（INE）地方住房价格统计数据和银行评估数据的直接查询。"},post_investir_p5:{pt:"N\xf3s n\xe3o trabalhamos com base em 'opini\xf5es', mas sim em m\xe9tricas de mercado. Acompanhamos estes indicadores diariamente para garantir que cada decis\xe3o de investimento seja fundamentada e segura.",en:"We do not work based on 'opinions', but on market metrics. We monitor these indicators daily to ensure that every investment decision is well-founded and secure.",fr:"Nous ne travaillons pas sur la base d'\xab opinions \xbb, mais sur des m\xe9triques de march\xe9. Nous suivons ces indicateurs quotidiennement pour garantir que chaque d\xe9cision d'investissement soit fond\xe9e et s\xe9curis\xe9e.",de:"Wir arbeiten nicht auf der Grundlage von „Meinungen“, sondern von Marktkennzahlen. Wir \xfcberwachen diese Indikatoren t\xe4glich, um sicherzustellen, dass jede Investitionsentscheidung fundiert und sicher ist.",es:"No trabajamos bas\xe1ndonos en 'opiniones', sino en m\xe9tricas de mercado. Supervisamos estos indicadores a diario para garantizar que cada decisi\xf3n de inversi\xf3n est\xe9 bien fundamentada y sea segura.",zh:"我们的工作不基于“意见”，而是基于市场指标。我们每天监控这些指标，以确保每一项投资决策都是有根据且安全的。"},post_investir_cta_title:{pt:"Se procura o pr\xf3ximo im\xf3vel com potencial de valoriza\xe7\xe3o em Lisboa, fale connosco.",en:"If you are looking for the next property with appreciation potential in Lisbon, talk to us.",fr:"Si vous recherchez le prochain bien avec un potentiel d'appr\xe9ciation \xe0 Lisbonne, parlez-nous.",de:"Wenn Sie nach der n\xe4chsten Immobilie mit Wertsteigerungspotenzial in Lissabon suchen, sprechen Sie mit uns.",es:"Si busca la pr\xf3xima propiedad con potencial de revalorizaci\xf3n en Lisboa, hable con nosotros.",zh:"如果您正在寻找里斯本下一处具有增值潜力的房产，请与我们联系。"},post_investir_cta_button_text:{pt:"Analisar o Mercado",en:"Analyze the Market",fr:"Analyser le March\xe9",de:"Markt analysieren",es:"Analizar el Mercado",zh:"分析市场"}}},1186:(e,a,n)=>{n.d(a,{bq:()=>p,eb:()=>f,gC:()=>g,l6:()=>u,yv:()=>c});var i=n(5155),r=n(2115),s=n(2623),o=n(9007),t=n(2614),d=n(2251),l=n(4269);let u=s.bL;s.YJ;let c=s.WT,p=r.forwardRef((e,a)=>{let{className:n,children:r,...t}=e;return(0,i.jsxs)(s.l9,{ref:a,className:(0,l.cn)("flex h-10 w-full items-center justify-between rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 [&>span]:line-clamp-1",n),...t,children:[r,(0,i.jsx)(s.In,{asChild:!0,children:(0,i.jsx)(o.A,{className:"h-4 w-4 opacity-50"})})]})});p.displayName=s.l9.displayName;let m=r.forwardRef((e,a)=>{let{className:n,...r}=e;return(0,i.jsx)(s.PP,{ref:a,className:(0,l.cn)("flex cursor-default items-center justify-center py-1",n),...r,children:(0,i.jsx)(t.A,{className:"h-4 w-4"})})});m.displayName=s.PP.displayName;let h=r.forwardRef((e,a)=>{let{className:n,...r}=e;return(0,i.jsx)(s.wn,{ref:a,className:(0,l.cn)("flex cursor-default items-center justify-center py-1",n),...r,children:(0,i.jsx)(o.A,{className:"h-4 w-4"})})});h.displayName=s.wn.displayName;let g=r.forwardRef((e,a)=>{let{className:n,children:r,position:o="popper",...t}=e;return(0,i.jsx)(s.ZL,{children:(0,i.jsxs)(s.UC,{ref:a,className:(0,l.cn)("relative z-50 max-h-96 min-w-[8rem] overflow-hidden rounded-md border bg-popover text-popover-foreground shadow-md data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95 data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2","popper"===o&&"data-[side=bottom]:translate-y-1 data-[side=l